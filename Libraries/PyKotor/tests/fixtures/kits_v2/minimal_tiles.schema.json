{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/PyKotor/PyKotor/fixtures/kits_v2/minimal_tiles.schema.json",
  "title": "IndoorKit_v2_minimal_fixture",
  "type": "object",
  "additionalProperties": true,
  "required": ["format_version", "name", "id", "templates"],
  "properties": {
    "format_version": { "const": 2 },
    "serializer": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "doors": { "type": "array" },
    "templates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["floors", "ceilings", "walls", "corners", "doorframes"],
      "properties": {
        "floors": { "$ref": "#/$defs/templateList" },
        "ceilings": { "$ref": "#/$defs/templateList" },
        "walls": { "$ref": "#/$defs/templateList" },
        "corners": { "$ref": "#/$defs/templateList" },
        "doorframes": { "$ref": "#/$defs/templateList" }
      }
    }
  },
  "$defs": {
    "templateList": {
      "type": "array",
      "items": { "$ref": "#/$defs/template" }
    },
    "template": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "resref": { "type": "string" },
        "offset": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "type": "number" }
        },
        "rotation": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "number" }
        },
        "doorhooks": { "type": "array" }
      }
    }
  }
}
