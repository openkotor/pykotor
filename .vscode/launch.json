{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "bashdb",
      "request": "launch",
      "name": "Bash-Debug (current file)",
      "cwd": "${workspaceFolder}",
      "program": "${file}",
      "args": []
    },
    {
      "name": "PowerShell Launch Current File",
      "type": "PowerShell",
      "request": "launch",
      "script": "${file}",
      "cwd": "${fileDirname}"
    },
    {
      "name": "Python C++ Debug",
      "type": "pythoncpp",
      "request": "launch",
      "pythonConfig": "default",
      "cppConfig": "default (win) Attach"
    },
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "K1_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\swkotor",
        "K2_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Knights of the Old Republic II"
      },
      "pythonArgs": [
        "-Xfrozen_modules=off",
        "-Xdev"
      ],
      "autoReload": {
        "enable": true
      }
    },
    {
      "name": "Run HolocronToolset",
      "type": "debugpy",
      "request": "launch",
      "module": "toolset.gui.editors.standalone",
      "cwd": "${workspaceFolder}/Tools/HolocronToolset/src/",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/Libraries/PyKotor/src;${env:PYTHONPATH}",
        "K1_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\swkotor",
        "K2_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Knights of the Old Republic II"
      },
      "pythonArgs": [
        "-Xfrozen_modules=off",
        "-Xdev"
      ],
      "justMyCode": false,
      "autoReload": {
        "enable": true
      }
    },
    {
      "name": "Run HoloPatcher",
      "type": "debugpy",
      "request": "launch",
      "module": "holopatcher.__main__",
      "cwd": "${workspaceFolder}/Tools/HoloPatcher/src/",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/Libraries/PyKotor/src;${env:PYTHONPATH}",
        "K1_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\swkotor",
        "K2_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Knights of the Old Republic II"
      },
      "pythonArgs": [
        "-Xfrozen_modules=off",
        "-Xdev"
      ],
      "justMyCode": true,
      "autoReload": {
        "enable": true
      }
    },
    {
      "name": "Run HoloPazaak",
      "type": "debugpy",
      "request": "launch",
      "module": "holopazaak.__main__",
      "cwd": "${workspaceFolder}/Tools/HoloPazaak/src/",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/Libraries/PyKotor/src;${env:PYTHONPATH}",
        "K1_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\swkotor",
        "K2_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Knights of the Old Republic II"
      },
      "pythonArgs": [
        "-Xfrozen_modules=off",
        "-Xdev"
      ],
      "justMyCode": false,
      "autoReload": {
        "enable": true
      }
    },
    {
      "name": "Run KotorDiff",
      "type": "debugpy",
      "request": "launch",
      "module": "kotordiff.__main__",
      "cwd": "${workspaceFolder}/Tools/KotorDiff/src/",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/Libraries/PyKotor/src;${env:PYTHONPATH}",
        "K1_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\swkotor",
        "K2_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Knights of the Old Republic II"
      },
      "pythonArgs": [
        "-Xfrozen_modules=off",
        "-Xdev"
      ],
      "justMyCode": true,
      "autoReload": {
        "enable": true
      }
    },
    {
      "name": "Run KotorMCP",
      "type": "debugpy",
      "request": "launch",
      "module": "kotormcp.server",
      "cwd": "${workspaceFolder}/Tools/KotorMCP/src/",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/Libraries/PyKotor/src;${env:PYTHONPATH}",
        "K1_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\swkotor",
        "K2_PATH": "C:\\Program Files (x86)\\Steam\\steamapps\\common\\Knights of the Old Republic II"
      },
      "pythonArgs": [
        "-Xfrozen_modules=off",
        "-Xdev"
      ],
      "justMyCode": true,
      "autoReload": {
        "enable": true
      }
    }
  ]
}
