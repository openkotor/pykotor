{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "toolPath",
      "type": "pickString",
      "description": "Select a tool under Tools/",
      "options": [
        "Tools/HolocronToolset",
        "Tools/HoloPatcher",
        "Tools/HoloPazaak",
        "Tools/KotorDiff",
        "Tools/KotorMCP"
      ],
      "default": "Tools/HolocronToolset"
    }
  ],
  "tasks": [
    {
      "label": "Install Workspace Dev Requirements",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "${workspaceFolder}${pathSeparator}requirements-dev.txt",
        "--progress-bar=on",
        "--prefer-binary",
        "--compile",
        "-U",
        "--upgrade-strategy=eager"
      ],
      "problemMatcher": []
    },
    {
      "label": "Install PyInstaller",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pip",
        "install",
        "pyinstaller"
      ],
      "problemMatcher": []
    },
    {
      "label": "Install Tool Requirements",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}${pathSeparator}compile${pathSeparator}deps_tool.ps1",
        "--tool",
        "${input:toolPath}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Build Tool",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}${pathSeparator}compile${pathSeparator}compile_tool.ps1",
        "--tool",
        "${input:toolPath}"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": []
    },
    {
      "label": "Sync Tooling Config",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "helper_scripts${pathSeparator}sync_tooling.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "Python: Ruff check entire project",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "ruff",
        "check",
        "."
      ],
      "problemMatcher": [
        "$eslint-stylish"
      ]
    }
  ]
}
