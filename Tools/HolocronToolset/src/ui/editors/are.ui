             </item>
             <item row="1" column="1">
              <widget class="QDoubleSpinBox" name="fogNearSpin">
               <property name="toolTip">
                <string>Near Distance (GFF: SunFogNear). FLOAT. Distance where fog
                 begins. K1 LoadAreaHeader ReadFieldFLOAT default 10000.0; engine
                 clamps negative to 0. Modders: lower = fog starts closer; pair
                 with SunFogFar.</string>
               </property>
               <property name="minimum">
                <double>0.0</double>
               </property>
               <property name="maximum">
                <double>10000.0</double>
               </property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="label_13">
               <property name="text">
                <string>Far Distance:</string>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="QDoubleSpinBox" name="fogFarSpin">
               <property name="toolTip">
                <string>Far Distance (GFF: SunFogFar). FLOAT. Distance where fog
                 reaches full density. Engine default 10000.0; clamps negative to
                 0. Modders: must be &gt; Near for visible fog; larger = fog
                 extends farther.</string>
               </property>
               <property name="minimum">
                <double>0.0</double>
               </property>
               <property name="maximum">
                <double>10000.0</double>
               </property>
              </widget>
             </item>
             <item row="0" column="0">
              <widget class="QLabel" name="label_14">
               <property name="text">
                <string>Color:</string>
