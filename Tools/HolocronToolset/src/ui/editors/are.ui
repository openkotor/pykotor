              <widget class="QDoubleSpinBox" name="alphaTestSpin">
               <property name="toolTip">
                <string>Alpha Test (GFF: AlphaTest). FLOAT. Transparency cutoff for
                 rendering; pixels below this are discarded. LoadAreaHeader
                 ReadFieldFLOAT default 0.2. Typical 0.0–1.0. Modders: lower = more
                 transparent; higher = more opaque. Affects water, particles,
                 foliage.</string>
               </property>
               <property name="minimum">
                <double>0.0</double>
               </property>
               <property name="maximum">
                <double>1.0</double>
               </property>
