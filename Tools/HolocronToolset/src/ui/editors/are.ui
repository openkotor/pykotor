          <layout class="QVBoxLayout" name="verticalLayout_7">
           <item>
            <widget class="QCheckBox" name="stealthCheck">
             <property name="toolTip">
              <string>Enabled (GFF: StealthXPEnabled). BYTE. When on, area grants
               stealth XP for successful sneaking; Max caps it, Loss is deducted when
               detected. Modders: use for stealth-focused areas.</string>
             </property>
             <property name="text">
              <string>Enabled</string>
             </property>
            </widget>
           </item>
           <item>
            <layout class="QFormLayout" name="formLayout_9">
             <item row="0" column="0">
              <widget class="QLabel" name="label_25">
               <property name="text">
                <string>Max:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QSpinBox" name="stealthMaxSpin">
               <property name="toolTip">
                <string>Max (GFF: StealthXPMax). DWORD. Maximum stealth XP pool for
                 this area. Engine reads via ReadFieldDWORD in
                 CSWSArea::LoadProperties from AreaProperties struct. Valid
                 0–4294967295; UI caps at 2147483647. Modders: enable Stealth XP
                 first; player gains XP up to this cap while sneaking undetected;
                 if current exceeds max on load, engine clamps current to max.</string>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>2147483647</number>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_26">
               <property name="text">
                <string>Loss:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QSpinBox" name="stealthLossSpin">
               <property name="toolTip">
                <string>Loss (GFF: StealthXPLoss). DWORD. Stealth XP deducted when
                 the player is detected. Engine reads via ReadFieldDWORD in
                 CSWSArea::LoadProperties from AreaProperties. Valid 0–4294967295;
                 UI caps at 2147483647. Modders: higher = harsher penalty for being
                 spotted; 0 = no loss on detection.</string>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>2147483647</number>
               </property>
              </widget>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
