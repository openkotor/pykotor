<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>507</width>
    <height>313</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>MainWindow</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QGridLayout" name="gridLayout">
    <item row="0" column="1">
     <widget class="QTabWidget" name="tabWidget">
      <property name="currentIndex">
       <number>0</number>
      </property>
      <widget class="QWidget" name="tab">
       <attribute name="title">
        <string>Basic</string>
       </attribute>
       <layout class="QGridLayout" name="gridLayout_2">
        <item row="0" column="0">
         <layout class="QFormLayout" name="formLayout_10">
          <item row="0" column="0">
           <widget class="QLabel" name="label_6">
            <property name="text">
             <string>Name:</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_15">
            <item>
             <widget class="LocalizedStringLineEdit" name="nameEdit" native="true">
              <property name="toolTip">
               <string>Name (GFF: LocalizedName). CExoLocString. Display name for the encounter;
                read via ReadFieldCExoLocString in ReadEncounterFromGff. Not shown to players at
                runtime—used by toolset for organization. Modders: optional; leave empty if not
                needed.</string>
              </property>
              <property name="minimumSize">
               <size>
                <width>0</width>
                <height>23</height>
               </size>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="label_14">
            <property name="text">
             <string>Tag:</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_16">
            <item>
             <widget class="QLineEdit" name="tagEdit">
              <property name="toolTip">
               <string>Tag (GFF: Tag). CExoString. Unique identifier for scripts; GetObjectByTag
                uses this. Must be unique per module if scripts reference it. Modders: set a
                descriptive tag (e.g. "enc_sith_ambush"); leave empty if no script reference.
                Duplicate tags in the same area can cause wrong object to be targeted.</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="tagGenerateButton">
              <property name="toolTip">
               <string>Generate tag from ResRef. Copies the Template ResRef into the Tag field so
                they stay in sync. Scripts reference encounters by Tag. Keep Tag unique per area.</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>26</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="2" column="0">
           <widget class="QLabel" name="label_38">
            <property name="text">
             <string>ResRef:</string>
            </property>
           </widget>
          </item>
          <item row="2" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_17">
            <item>
             <widget class="QLineEdit" name="resrefEdit">
              <property name="toolTip">
               <string>Template ResRef (GFF: TemplateResRef). ResRef (max 16 chars). When the area
                loads, the engine uses this to find the UTE template. Modders: match the UTE
                filename (without .ute); keep under 16 characters.</string>
              </property>
              <property name="maxLength">
               <number>16</number>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="resrefGenerateButton">
              <property name="toolTip">
               <string>Generate ResRef from Tag. Copies the Tag into the Template ResRef field (max
                16 characters). ResRef should match the UTE filename.</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>26</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="3" column="0">
           <widget class="QLabel" name="label_39">
            <property name="text">
             <string>Difficulty:</string>
            </property>
           </widget>
          </item>
          <item row="3" column="1">
           <widget class="ComboBox2DA" name="difficultySelect">
            <property name="toolTip">
             <string>Difficulty (GFF: DifficultyIndex). INT32 index into encdifficulty.2da.
              Determines encounter scaling and difficulty modifiers. Engine reads via ReadFieldINT
              in LoadEncounter; uses VALUE from encdifficulty.2da when present. Modders: choose a
              row from encdifficulty.2da; -1 uses default.</string>
            </property>
           </widget>
          </item>
          <item row="4" column="0">
           <widget class="QLabel" name="label_40">
            <property name="text">
             <string>Min Creatures:</string>
            </property>
           </widget>
          </item>
          <item row="4" column="1">
           <widget class="QSpinBox" name="minCreatureSpin">
            <property name="toolTip">
             <string>Min Creatures (GFF: RecCreatures). INT32. Recommended minimum creatures to
              spawn; engine uses this with difficulty to select from CreatureList. Engine reads via
              ReadFieldINT in LoadEncounter. Modders: valid range 0–32767; typical 1–5. Must be
              &lt;= Max Creatures.</string>
            </property>
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>32767</number>
            </property>
           </widget>
          </item>
          <item row="5" column="0">
           <widget class="QLabel" name="label_41">
            <property name="text">
             <string>Max Creatures:</string>
            </property>
           </widget>
          </item>
          <item row="5" column="1">
           <widget class="QSpinBox" name="maxCreatureSpin">
            <property name="toolTip">
             <string>Max Creatures (GFF: MaxCreatures). INT32. Maximum creatures that can spawn from
              this encounter. Engine reads via ReadFieldINT in LoadEncounter. Modders: valid range
              0–32767; typical 1–10. Must be &gt;= Min Creatures.</string>
            </property>
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>32767</number>
            </property>
           </widget>
          </item>
          <item row="6" column="0">
           <widget class="QLabel" name="label_42">
            <property name="text">
             <string>Spawn Option:</string>
            </property>
           </widget>
          </item>
          <item row="6" column="1">
           <widget class="QComboBox" name="spawnSelect">
            <property name="toolTip">
             <string>Spawn Option (GFF: SpawnOption). Single Shot = spawns once when triggered;
              Continuous = can respawn (if Respawns &gt; 0). Engine reads via ReadFieldINT in
              LoadEncounter. Modders: Single Shot for one-time ambushes; Continuous for respawning
              encounters.</string>
            </property>
            <item>
             <property name="text">
              <string>Single Shot</string>
             </property>
            </item>
            <item>
             <property name="text">
              <string>Continuous</string>
             </property>
            </item>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_2">
       <attribute name="title">
        <string>Advanced</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_2">
        <item>
         <layout class="QVBoxLayout" name="verticalLayout">
          <item>
           <widget class="QCheckBox" name="activeCheckbox">
            <property name="toolTip">
             <string>Active (GFF: Active). BYTE 0/1. When set, the encounter can trigger when the
              player enters. When unset, the encounter is disabled until a script activates it.
              Engine reads via ReadFieldBYTE in LoadEncounter. Modders: enable for encounters that
              should trigger on entry; leave off for script-controlled spawns.</string>
            </property>
            <property name="text">
             <string>Active</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="playerOnlyCheckbox">
            <property name="toolTip">
             <string>Player Triggered Only (GFF: PlayerOnly). BYTE 0/1. When set, only the player
              can trigger the encounter; party members entering alone do not. Engine reads via
              ReadFieldBYTE in LoadEncounter. Modders: enable for encounters that must wait for the
              player; leave off if followers can trigger it.</string>
            </property>
            <property name="text">
             <string>Player Triggered Only</string>
            </property>
           </widget>
          </item>
          <item>
           <layout class="QFormLayout" name="formLayout">
            <item row="0" column="0">
             <widget class="QLabel" name="label">
              <property name="text">
               <string>Faction:</string>
              </property>
             </widget>
            </item>
            <item row="0" column="1">
             <widget class="ComboBox2DA" name="factionSelect">
              <property name="toolTip">
               <string>Faction (GFF: Faction). DWORD index into repute.2da. Sets the faction of
                spawned creatures. Engine reads via ReadFieldDWORD in LoadEncounter. Modders: choose
                a row from repute.2da; typically matches area hostiles.</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
         </layout>
        </item>
        <item>
         <widget class="Line" name="line">
          <property name="orientation">
           <enum>Qt::Horizontal</enum>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="respawnsCheckbox">
          <property name="toolTip">
           <string>Respawns (GFF: Reset). BYTE 0/1. When set, the encounter can reset after being
            exhausted; combined with Respawn Time and Number of Respawns. Engine reads via
            ReadFieldBYTE in LoadEncounter. Modders: enable for encounters that should come back
            after a delay.</string>
          </property>
          <property name="text">
           <string>Respawns</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QCheckBox" name="infiniteRespawnCheckbox">
          <property name="toolTip">
           <string>Infinite Respawns. When set, stores -1 in Respawns (GFF: Respawns). The encounter
            resets indefinitely after each exhaustion. Modders: enable for farming encounters;
            disable to limit respawns to the Number of Respawns value.</string>
          </property>
          <property name="text">
           <string>Infinite Respawns</string>
          </property>
         </widget>
        </item>
        <item>
         <layout class="QFormLayout" name="formLayout_2">
          <item row="0" column="0">
           <widget class="QLabel" name="label_2">
            <property name="text">
             <string>Respawn Time (s):</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="QSpinBox" name="respawnTimeSpin">
            <property name="toolTip">
             <string>Respawn Time (GFF: ResetTime). INT32 seconds before the encounter resets after
              exhaustion. Engine reads via ReadFieldINT in LoadEncounter. Modders: valid range
              0–2147483647; typical 60–300. Only used when Respawns is checked.</string>
            </property>
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>2147483647</number>
            </property>
           </widget>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="label_3">
            <property name="text">
             <string>Number of Respawns:</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <widget class="QSpinBox" name="respawnCountSpin">
            <property name="toolTip">
             <string>Number of Respawns (GFF: Respawns). INT32. How many times the encounter can
              reset; -1 = infinite. Engine reads via ReadFieldINT in LoadEncounter. Modders: use 0
              for no respawns; -1 for infinite; 1–32767 for limited respawns. Enable Infinite
              Respawns to set -1.</string>
            </property>
            <property name="minimum">
             <number>-1</number>
            </property>
            <property name="maximum">
             <number>32767</number>
            </property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <spacer name="verticalSpacer">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>40</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_5">
       <attribute name="title">
        <string>Creatures</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_3">
        <item>
         <widget class="QTableWidget" name="creatureTable">
          <property name="toolTip">
           <string>Creature List (GFF: CreatureList). Each row is a spawnable creature: SingleSpawn
            (BYTE), CR (FLOAT challenge rating), Appearance (INT32, toolset-only), ResRef (creature
            UTC). Engine selects from this list based on Min/Max Creatures and difficulty. Modders:
            add creature templates; CR affects selection weighting.</string>
          </property>
          <property name="alternatingRowColors">
           <bool>true</bool>
          </property>
          <property name="selectionMode">
           <enum>QAbstractItemView::SingleSelection</enum>
          </property>
          <attribute name="horizontalHeaderStretchLastSection">
           <bool>true</bool>
          </attribute>
          <column>
           <property name="text">
            <string>SingleSpawn</string>
           </property>
          </column>
          <column>
           <property name="text">
            <string>CR</string>
           </property>
          </column>
          <column>
           <property name="text">
            <string>Appearance</string>
           </property>
          </column>
          <column>
           <property name="text">
            <string>ResRef</string>
           </property>
          </column>
         </widget>
        </item>
        <item>
         <layout class="QHBoxLayout" name="horizontalLayout">
          <item>
           <spacer name="horizontalSpacer">
            <property name="orientation">
             <enum>Qt::Horizontal</enum>
            </property>
            <property name="sizeHint" stdset="0">
             <size>
              <width>40</width>
              <height>20</height>
             </size>
            </property>
           </spacer>
          </item>
          <item>
           <widget class="QPushButton" name="removeCreatureButton">
            <property name="toolTip">
             <string>Remove the selected creature from the spawn list. The creature will no longer
              be eligible to spawn from this encounter.</string>
            </property>
            <property name="text">
             <string>Remove</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="addCreatureButton">
            <property name="toolTip">
             <string>Add a new creature to the spawn list. Choose a creature template (UTC); the
              engine will randomly select from the list when the encounter triggers.</string>
            </property>
            <property name="text">
             <string>Add</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_3">
       <attribute name="title">
        <string>Scripts</string>
       </attribute>
       <layout class="QGridLayout" name="gridLayout_4">
        <item row="0" column="0">
         <layout class="QFormLayout" name="formLayout_3">
          <item row="0" column="0">
           <widget class="QLabel" name="label_4">
            <property name="text">
             <string>OnEnter:</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="FilterComboBox" name="onEnterSelect">
            <property name="toolTip">
             <string>OnEntered (GFF: OnEntered). ResRef of NCS script (max 16 chars). Fires when the
              player enters the encounter area. Leave blank for no script. Modders: use for custom
              spawn logic or triggers.</string>
            </property>
           </widget>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="label_5">
            <property name="text">
             <string>OnExit:</string>
            </property>
           </widget>
          </item>
          <item row="2" column="0">
           <widget class="QLabel" name="label_7">
            <property name="text">
             <string>OnExhausted:</string>
            </property>
           </widget>
          </item>
          <item row="3" column="0">
           <widget class="QLabel" name="label_8">
            <property name="text">
             <string>OnHeartbeat:</string>
            </property>
           </widget>
          </item>
          <item row="4" column="0">
           <widget class="QLabel" name="label_9">
            <property name="text">
             <string>OnUserDefined:</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <widget class="FilterComboBox" name="onExitSelect">
            <property name="toolTip">
             <string>OnExit (GFF: OnExit). ResRef of NCS script. Fires when the player leaves the
              encounter area. Leave blank for no script. Max 16 characters.</string>
            </property>
           </widget>
          </item>
          <item row="2" column="1">
           <widget class="FilterComboBox" name="onExhaustedEdit">
            <property name="toolTip">
             <string>OnExhausted (GFF: OnExhausted). ResRef of NCS script. Fires when all spawns
              from the encounter are defeated. Leave blank for no script. Max 16 characters.</string>
            </property>
           </widget>
          </item>
          <item row="3" column="1">
           <widget class="FilterComboBox" name="onHeartbeatSelect">
            <property name="toolTip">
             <string>OnHeartbeat (GFF: OnHeartbeat). ResRef of NCS script. Fires periodically while
              the encounter is active. Leave blank for no script. Max 16 characters.</string>
            </property>
           </widget>
          </item>
          <item row="4" column="1">
           <widget class="FilterComboBox" name="onUserDefinedSelect">
            <property name="toolTip">
             <string>OnUserDefined (GFF: OnUserDefined). ResRef of NCS script. Fires on user-defined
              events (e.g. from AssignCommand). Leave blank for no script. Max 16 characters.</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_4">
       <attribute name="title">
        <string>Comments</string>
       </attribute>
       <layout class="QGridLayout" name="gridLayout_3">
        <item row="0" column="0">
         <widget class="QPlainTextEdit" name="commentsEdit">
          <property name="toolTip">
           <string>Comment (GFF: Comment). Developer notes; not used by the game at runtime.
            Modders: use for documentation or reminders about this encounter.</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>
