            <item row="0" column="1">
             <widget class="ComboBox2DA" name="trapSelect">
              <property name="toolTip">
               <string>Trap Type (GFF: TrapType). BYTE. Trap type from traps.2da. Default when
                missing: 0. Modders: used when Is a trap is set.</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QCheckBox" name="detectableCheckbox">
          <property name="toolTip">
           <string>Detectable (GFF: TrapDetectable). BYTE. Trap can be detected by skills. Default
            when missing: 0. Modders: use with Detect DC.</string>
          </property>
          <property name="text">
           <string>Detectable</string>
          </property>
         </widget>
        </item>
        <item>
         <layout class="QFormLayout" name="formLayout">
          <item row="0" column="0">
           <widget class="QLabel" name="label_4">
            <property name="text">
             <string>Detect DC:</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="QSpinBox" name="detectDcSpin">
            <property name="toolTip">
             <string>Detect DC (GFF: TrapDetectDC). BYTE 0–255. Difficulty class for Awareness to
              detect the trap. Note: K1 LoadTrigger does not read this—trigger DC comes from
              traps.2da DetectDCMod. PyKotor stores it for GFF compatibility (doors/placeables use
              it). Modders: set 0–255; used when Detectable is checked. Doors and placeables read
              this field; triggers use traps.2da.</string>
            </property>
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>255</number>
            </property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QCheckBox" name="disarmableCheckbox">
          <property name="toolTip">
           <string>Disarmable (GFF: TrapDisarmable). BYTE. Trap can be disarmed. Default when
            missing: 0. Modders: use with Disarm DC.</string>
          </property>
          <property name="text">
           <string>Disarmable</string>
          </property>
         </widget>
        </item>
        <item>
         <layout class="QFormLayout" name="formLayout_2">
          <item row="0" column="0">
           <widget class="QLabel" name="label_5">
            <property name="text">
             <string>Disarm DC:</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="QSpinBox" name="disarmDcSpin">
            <property name="toolTip">
             <string>Disarm DC (GFF: DisarmDC). BYTE 0–255. Difficulty class for Security to disarm
              the trap. Note: K1 LoadTrigger does not read this—trigger DC comes from traps.2da
              DisarmDCMod. PyKotor stores it for GFF compatibility (doors/placeables use it).
              Modders: set 0–255; used when Disarmable is checked. Doors and placeables read this
              field; triggers use traps.2da.</string>
            </property>
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>255</number>
            </property>
           </widget>
          </item>
         </layout>
        </item>
