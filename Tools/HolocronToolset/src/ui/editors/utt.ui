           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="activateOnceCheckbox">
            <property name="toolTip">
             <string>Activate Once (GFF: TrapOneShot). BYTE. Trap fires only once. Default when
              missing: 0. Modders: 0 = repeatable, 1 = one shot.</string>
            </property>
            <property name="text">
             <string>Activate Once</string>
            </property>
           </widget>
