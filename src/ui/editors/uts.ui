       <attribute name="title">
        <string>Basic</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout">
        <item>
         <layout class="QFormLayout" name="formLayout">
          <item row="0" column="0">
           <widget class="QLabel" name="label_6">
            <property name="text">
             <string>Name:</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_18">
            <item>
             <widget class="LocalizedStringLineEdit" name="nameEdit" native="true">
              <property name="minimumSize">
               <size>
                <width>0</width>
                <height>23</height>
               </size>
              </property>
              <property name="toolTip">
               <string>Name (GFF: LocName). Localized display name. The engine does not read this
                field in CSWSSoundObject::Load—used only by the toolset and module
                editors for identification. Modders: optional; leave empty if not needed. Does not
                affect in-game sound playback.</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="label_14">
            <property name="text">
             <string>Tag:</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_19">
            <item>
             <widget class="QLineEdit" name="tagEdit">
              <property name="toolTip">
               <string>Tag (GFF: Tag). CExoString. Unique identifier for this sound object. The
                engine reads it via ReadFieldCExoString in CSWSSoundObject::Load.
                Scripts use GetObjectByTag to target this sound (e.g. SoundObjectPlay,
                SoundObjectSetVolume). Modders: keep unique per area; duplicate tags can cause wrong
                object to be targeted. Used when placing instances in the area (GIT SoundList).</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="tagGenerateButton">
              <property name="toolTip">
               <string>Generate tag from ResRef. Copies the Template ResRef into the Tag field so
                they stay in sync. Scripts reference sound objects by Tag; keep Tag unique per area.</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>26</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="2" column="0">
           <widget class="QLabel" name="label_38">
            <property name="text">
             <string>ResRef:</string>
            </property>
           </widget>
          </item>
          <item row="2" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_20">
            <item>
             <widget class="QLineEdit" name="resrefEdit">
              <property name="maxLength">
               <number>16</number>
              </property>
              <property name="toolTip">
               <string>Template ResRef (GFF: TemplateResRef). ResRef (max 16 characters) of this UTS
                template; .uts extension implied. The engine stores ResRefs in 16 bytes. When the
                game loads a sound from a GIT file it uses TemplateResRef to find the UTS template
                (LoadFromTemplate). Modders: set to match the UTS filename (without .uts);
                keep under 16 characters. Must match the .uts filename or area instances may
                fail to load.</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="resrefGenerateButton">
              <property name="toolTip">
               <string>Generate ResRef from Tag. Copies the Tag into the Template ResRef field (max
                16 characters). ResRef should match the UTS filename for area placement to work.</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>26</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="3" column="0">
           <widget class="QLabel" name="label">
            <property name="text">
             <string>Volume:</string>
            </property>
           </widget>
          </item>
          <item row="3" column="1">
           <widget class="QSlider" name="volumeSlider">
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>255</number>
            </property>
            <property name="orientation">
             <enum>Qt::Horizontal</enum>
            </property>
            <property name="toolTip">
             <string>Volume (GFF: Volume). BYTE 0–255. Engine reads via ReadFieldBYTE in
              CSWSSoundObject::Load. Master volume for this sound object; 0 =
              silent, 255 = full. In-game: used for ambient sounds (wind, rain, machinery). Modders:
              127 is roughly half volume; typical range 64–255. Affects all sounds in the Sounds
              list when played from this object.</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QCheckBox" name="activeCheckbox">
          <property name="text">
           <string>Active</string>
          </property>
          <property name="toolTip">
           <string>Active (GFF: Active). BYTE 0/1. Engine reads via ReadFieldBYTE in
            CSWSSoundObject::Load. When checked (1), the sound object is enabled
            and will play when conditions are met (e.g. in area, interval elapsed). Unchecked (0) =
            disabled; the sound will not play in-game. Modders: use to disable ambient sounds
            without deleting the object; scripts can also toggle active state at runtime.</string>
          </property>
         </widget>
        </item>
        <item>
         <spacer name="verticalSpacer">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>132</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_2">
       <attribute name="title">
        <string>Advanced</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_5">
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_4">
          <item>
           <layout class="QHBoxLayout" name="horizontalLayout">
            <item>
             <widget class="QGroupBox" name="styleGroup">
              <property name="title">
               <string>Play Style</string>
              </property>
              <layout class="QVBoxLayout" name="verticalLayout_2">
               <item>
                <widget class="QRadioButton" name="styleOnceRadio">
                 <property name="text">
                  <string>Once</string>
                 </property>
                 <property name="checked">
                  <bool>true</bool>
                 </property>
                 <property name="toolTip">
                  <string>Play Style: Once. GFF: Continuous=0, Looping=0. Sound plays a single time
                   then stops. Use for one-shot ambient events (e.g. a creak, bird call).</string>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QRadioButton" name="styleRepeatRadio">
                 <property name="text">
                  <string>Repeating</string>
                 </property>
                 <property name="toolTip">
                  <string>Play Style: Repeating. GFF: Continuous=0, Looping=1. Sound loops with a
                   gap between plays. Interval and Interval Variation control timing. Use for
                   periodic ambience (e.g. distant thunder).</string>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QRadioButton" name="styleSeamlessRadio">
                 <property name="text">
                  <string>Seamless Looping</string>
                 </property>
                 <property name="toolTip">
                  <string>Play Style: Seamless Looping. GFF: Continuous=1, Looping=1. Sound plays
                   continuously with no gap. Best for ambient beds (e.g. wind, rain). Requires a
                   loopable .wav file.</string>
                 </property>
                </widget>
               </item>
              </layout>
             </widget>
            </item>
            <item>
             <widget class="QGroupBox" name="orderGroup">
              <property name="title">
               <string>Play Order</string>
              </property>
              <layout class="QVBoxLayout" name="verticalLayout_3">
               <item>
                <widget class="QRadioButton" name="orderSequentialRadio">
                 <property name="toolTip">
                  <string>Play Order: Sequential. GFF: Random=0. Sounds from the list play in order
                   (first, second, third…). When the list ends, playback wraps to the start. Use for
                   ordered ambient sequences (e.g. bird calls in a fixed pattern). Engine reads
                   Random via ReadFieldBYTE in CSWSSoundObject::Load.</string>
                 </property>
                 <property name="text">
                  <string>Sequential</string>
                 </property>
                 <property name="checked">
                  <bool>false</bool>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QRadioButton" name="orderRandomRadio">
                 <property name="toolTip">
                  <string>Play Order: Random. GFF: Random=1. Each time a sound is due to play, the
                   engine picks one at random from the Sounds list. Use for varied ambient (e.g.
                   random bird or insect sounds). Engine reads Random via ReadFieldBYTE in
                   CSWSSoundObject::Load.</string>
                 </property>
                 <property name="text">
                  <string>Random</string>
                 </property>
                 <property name="checked">
                  <bool>true</bool>
                 </property>
                </widget>
               </item>
              </layout>
             </widget>
            </item>
           </layout>
          </item>
          <item>
           <widget class="QGroupBox" name="intervalGroup">
            <property name="title">
             <string>Interval</string>
            </property>
            <layout class="QFormLayout" name="formLayout_2">
             <item row="0" column="0">
              <widget class="QLabel" name="label_2">
               <property name="text">
                <string>Interval between sounds (s):</string>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_3">
               <property name="text">
                <string>Interval variation (s):</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QSpinBox" name="intervalSpin">
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>2147483647</number>
               </property>
               <property name="toolTip">
                <string>Interval (GFF: Interval). DWORD. Engine reads via ReadFieldDWORD in
                 CSWSSoundObject::Load. Seconds between sound plays when using
                 Repeating mode. Valid range 0–4294967295; UI caps at 2147483647. 0 = play as fast
                 as possible; 10–60 typical for ambient. Only used when Looping or Repeating is
                 enabled. Modders: set in seconds; high values (e.g. 3600) for rare ambient events.</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QSpinBox" name="intervalVariationSpin">
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>2147483647</number>
               </property>
               <property name="toolTip">
                <string>Interval Variation (GFF: IntervalVrtn). DWORD. Engine reads via
                 ReadFieldDWORD in CSWSSoundObject::Load. Random variation (in
                 seconds) added to the interval each time. E.g. Interval 30 + Variation 10 = plays
                 every 30±10 seconds. Used with Repeating mode. Modders: 0 = fixed interval; higher
                 values add variety. Valid range 0–4294967295.</string>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QGroupBox" name="variationGroup">
          <property name="title">
           <string>Variation</string>
          </property>
          <layout class="QFormLayout" name="formLayout_3">
           <item row="0" column="0">
            <widget class="QLabel" name="label_4">
             <property name="text">
              <string>Volume Variation:</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QSlider" name="volumeVariationSlider">
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>255</number>
             </property>
             <property name="orientation">
              <enum>Qt::Horizontal</enum>
             </property>
             <property name="toolTip">
              <string>Volume Variation (GFF: VolumeVrtn). BYTE 0–255. Engine reads via ReadFieldBYTE
               in CSWSSoundObject::Load. Random variation added to the base Volume
               each time a sound plays. 0 = no variation; higher values create more dynamic ambient.
               Modders: typical 0–32; very high values can make some plays inaudible or too loud.</string>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="label_5">
             <property name="text">
              <string>Pitch Variation:</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QSlider" name="pitchVariationSlider">
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="orientation">
              <enum>Qt::Horizontal</enum>
             </property>
             <property name="toolTip">
              <string>Pitch Variation (GFF: PitchVariation). FLOAT. Engine reads via ReadFieldFLOAT
               in CSWSSoundObject::Load. Random pitch shift per play; UI shows
               0–100% (stored as 0.0–1.0). 0 = no variation; 0.5 = ±50% pitch. Modders: adds variety
               to repeated sounds; high values can sound unnatural. No engine clamp; keep 0–1 for
               predictable behavior.</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <spacer name="verticalSpacer_2">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>40</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_3">
       <attribute name="title">
        <string>Sounds</string>
       </attribute>
       <layout class="QHBoxLayout" name="horizontalLayout_3">
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_9">
          <item>
           <widget class="QListWidget" name="soundList">
            <property name="editTriggers">
             <set>QAbstractItemView::DoubleClicked|QAbstractItemView::EditKeyPressed</set>
            </property>
            <property name="alternatingRowColors">
             <bool>true</bool>
            </property>
            <property name="toolTip">
             <string>Sounds (GFF: Sounds list). Engine reads via GetList("Sounds") and each
              element's ReadFieldCResRef("Sound") in CSWSSoundObject::Load. List
              of .wav ResRefs (max 16 chars each). Order matters when Play Order is Sequential;
              Random picks from list. Double-click to edit a ResRef. Add/Remove to manage entries.
              At least one valid sound recommended; empty list may cause no audio. ResRefs without
              extension refer to .wav files.</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_8">
          <item>
           <widget class="QPushButton" name="addSoundButton">
            <property name="toolTip">
             <string>Add a new sound to the list. Appends an entry to the Sounds list (GFF); you can
              then set its .wav ResRef (max 16 characters). At least one sound is recommended for
              the object to play audio in-game.</string>
            </property>
            <property name="text">
             <string>Add</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="removeSoundButton">
            <property name="toolTip">
             <string>Remove the selected sound from the list. Deletes the ResRef from the Sounds
              list. The list can be empty, but the sound object will not play any audio in-game
              until at least one valid sound is added.</string>
            </property>
            <property name="text">
             <string>Remove</string>
            </property>
           </widget>
          </item>
          <item>
           <spacer name="verticalSpacer_4">
            <property name="orientation">
             <enum>Qt::Vertical</enum>
            </property>
            <property name="sizeHint" stdset="0">
             <size>
              <width>20</width>
              <height>40</height>
             </size>
            </property>
           </spacer>
          </item>
          <item>
           <widget class="QPushButton" name="moveUpButton">
            <property name="toolTip">
             <string>Move the selected sound one position up in the list. Order matters when Play
              Order is Sequential; the engine plays sounds in list order. When Random is selected,
              order has no effect.</string>
            </property>
            <property name="text">
             <string>Move Up</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="moveDownButton">
            <property name="toolTip">
             <string>Move the selected sound one position down in the list. Order matters when Play
              Order is Sequential.</string>
            </property>
            <property name="text">
             <string>Move Down</string>
            </property>
           </widget>
          </item>
          <item>
           <spacer name="verticalSpacer_5">
            <property name="orientation">
             <enum>Qt::Vertical</enum>
            </property>
            <property name="sizeHint" stdset="0">
             <size>
              <width>20</width>
              <height>40</height>
             </size>
            </property>
           </spacer>
          </item>
          <item>
           <widget class="QPushButton" name="playSoundButton">
            <property name="toolTip">
             <string>Play the selected sound in the list (or the first if none selected). Uses the
              toolset's audio player to preview the .wav; does not affect the UTS file. Useful to
              verify ResRefs point to valid audio.</string>
            </property>
            <property name="text">
             <string>Play</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="stopSoundButton">
            <property name="toolTip">
             <string>Stop the currently playing preview sound. Only affects the toolset preview, not
              in-game playback.</string>
            </property>
            <property name="text">
             <string>Stop</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_4">
       <attribute name="title">
        <string>Positioning</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_7">
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_6">
          <item>
           <widget class="QRadioButton" name="playEverywhereRadio">
            <property name="text">
             <string>Plays everywhere in area</string>
            </property>
            <property name="toolTip">
             <string>Position: Plays everywhere. GFF: Positional=0, RandomPosition=0.
              Non-positional; sound is heard at full volume anywhere in the area. Use for background
              ambience (wind, rain).</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QRadioButton" name="playRandomRadio">
            <property name="text">
             <string>Plays from a random position each time</string>
            </property>
            <property name="toolTip">
             <string>Position: Random. GFF: Positional=1, RandomPosition=1. Sound plays from a
              random point each time. North/South and East/West ranges define the randomization
              area. Use for scattered ambient (birds, insects).</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QRadioButton" name="playSpecificRadio">
            <property name="text">
             <string>Plays from a specific position</string>
            </property>
            <property name="toolTip">
             <string>Position: Specific. GFF: Positional=1, RandomPosition=0. 3D positional sound
              from the object's placed location. Volume falls off with distance (MinDistance,
              MaxDistance). Use for localized sources (fountain, machinery).</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QGroupBox" name="distanceGroup">
          <property name="title">
           <string>Volume Distances</string>
          </property>
          <layout class="QFormLayout" name="formLayout_4">
           <item row="0" column="0">
            <widget class="QLabel" name="label_7">
             <property name="text">
              <string>Cutoff Distance (m):</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QDoubleSpinBox" name="cutoffSpin">
             <property name="toolTip">
              <string>Cutoff Distance (GFF: MinDistance). FLOAT meters. Engine reads via
               ReadFieldFLOAT in
               CSWSSoundObject::Load. Distance beyond which the sound is no longer
               audible (for positional sounds). Used when "Plays from a specific position" is
               selected.
               Modders: 0 = no cutoff; typical 5–50. Beyond MaxVolumeDistance volume falls off;
               beyond
               MinDistance sound is silent. Set MaxDistance &lt; MinDistance for normal falloff.</string>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <double>10000.0</double>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="label_8">
             <property name="text">
              <string>Max Volume Distance (m):</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QDoubleSpinBox" name="maxVolumeDistanceSpin">
             <property name="toolTip">
              <string>Max Volume Distance (GFF: MaxDistance). FLOAT meters. Engine reads via
               ReadFieldFLOAT
               in CSWSSoundObject::Load. Distance within which sound plays at full
               volume (positional sounds). Beyond this, volume falls off until MinDistance (cutoff).
               Modders: set MaxDistance &lt; MinDistance (e.g. full volume to 10 m, cutoff at 30 m).
               Reversing them can cause odd behavior.</string>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <double>10000.0</double>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <layout class="QHBoxLayout" name="horizontalLayout_2">
          <item>
           <widget class="QGroupBox" name="heightGroup">
            <property name="title">
             <string>Height</string>
            </property>
            <layout class="QFormLayout" name="formLayout_5">
             <item row="0" column="0">
              <widget class="QLabel" name="label_9">
               <property name="text">
                <string>Height (m):</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QDoubleSpinBox" name="heightSpin">
               <property name="toolTip">
                <string>Height (GFF: Elevation). FLOAT meters. Vertical offset. K1
                 CSWSSoundObject::Load
                 does NOT read Elevation—only XPosition, YPosition, ZPosition and
                 RandomRangeX/Y. Height in-game comes from the placed instance position (GIT). This
                 field is stored for toolset/TSL; may be unused. Modders: set for documentation.</string>
               </property>
               <property name="minimum">
                <double>-10000.0</double>
               </property>
               <property name="maximum">
                <double>10000.0</double>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <widget class="QGroupBox" name="rangeGroup">
            <property name="title">
             <string>Random Range:</string>
            </property>
            <layout class="QFormLayout" name="formLayout_6">
             <item row="0" column="0">
              <widget class="QLabel" name="label_10">
               <property name="text">
                <string>North/South (m):</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QDoubleSpinBox" name="northRandomSpin">
               <property name="toolTip">
                <string>North/South Random Range (GFF: RandomRangeY). FLOAT meters. When "Plays from
                 a
                 random position" is selected, sound spawns within ±this distance on the Y axis.
                 Engine
                 reads via ReadFieldFLOAT in CSWSSoundObject::Load. Modders: 0 = no
                 north/south variation; typical 5–50.</string>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <double>10000.0</double>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
