            <string>Click to expand model information...</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QLabel" name="modelInfoLabel">
           <property name="toolTip">
            <string>Detailed model information (meshes, animations, bounds) for the door. Shown when
             Model Info is expanded. Helps modders confirm the door appearance matches expectations.
             Not stored in the UTD GFF.</string>
           </property>
           <property name="sizePolicy">
            <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
