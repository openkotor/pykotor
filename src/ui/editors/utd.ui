      <widget class="QWidget" name="tab_10">
       <attribute name="title">
        <string>Advanced</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout">
        <item>
         <widget class="QGroupBox" name="groupBox_16">
          <property name="title">
           <string>Flags</string>
          </property>
          <layout class="QGridLayout" name="gridLayout">
           <item row="0" column="0">
            <widget class="QCheckBox" name="min1HpCheckbox">
             <property name="toolTip">
              <string>Min1HP (GFF: Min1HP). BYTE 0/1. When set, the door cannot be reduced below 1
               HP by damage—it stays at 1 until destroyed by script or other means. Engine reads via
               ReadFieldBYTE in LoadDoor. KotOR 2 only in some builds. Modders: enable for doors
               that should be nearly unbreakable.</string>
             </property>
             <property name="text">
              <string>Min1HP</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QCheckBox" name="plotCheckbox">
             <property name="toolTip">
              <string>Plot (GFF: Plot). BYTE 0/1. When set, the door is plot-critical: it cannot be
               destroyed (treated as invulnerable if Static is not set). Engine reads
               Plot/Invulnerable/Static in LoadDoor and sets object.plot. Modders: enable for story
               doors that must never be broken.</string>
             </property>
             <property name="text">
              <string>Plot</string>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QCheckBox" name="partyInteractCheckbox">
             <property name="toolTip">
              <string>Party Interact. When set, the party can interact with this door (e.g. open,
               use dialogue). Used by the toolset/scripts; behavior may vary by game. Modders:
               enable for doors the player should be able to use.</string>
             </property>
             <property name="text">
              <string>Party Interact</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QCheckBox" name="staticCheckbox">
             <property name="toolTip">
              <string>Static (GFF: Static). BYTE 0/1. When set, the door is non-interactive (no
               open/close, no dialogue). Engine reads via ReadFieldBYTE in LoadDoor; if Static is 0,
               Plot flag still makes it invulnerable. Modders: use for decorative or script-only
               doors.</string>
             </property>
             <property name="text">
              <string>Static</string>
             </property>
            </widget>
           </item>
           <item row="2" column="0">
            <widget class="QCheckBox" name="useableCheckbox">
             <property name="toolTip">
              <string>Useable. When set, the door can be used (opened, conversation). Modders:
               enable for normal doors the player can interact with; disable for decoration or doors
               opened only by script.</string>
             </property>
             <property name="text">
              <string>Useable</string>
             </property>
            </widget>
           </item>
           <item row="2" column="1">
            <widget class="QCheckBox" name="notBlastableCheckbox">
             <property name="toolTip">
              <string>Not Blastable (GFF: NotBlastable). KotOR 2 only. When set, the door cannot be
               blasted open (e.g. with explosives). Modders: enable for doors that must be unlocked
               or opened by key/script only.</string>
             </property>
             <property name="text">
              <string>Not Blastable</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_17">
          <property name="title">
           <string>Other</string>
          </property>
          <layout class="QFormLayout" name="formLayout_11">
           <item row="0" column="0">
            <widget class="QLabel" name="label_41">
             <property name="text">
              <string>Faction:</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="ComboBox2DA" name="factionSelect">
             <property name="toolTip">
              <string>Faction (GFF: Faction). DWORD. Faction identifier; determines hostility and
               who can use the door. Engine reads via ReadFieldDWORD in LoadDoor. Modders: set to
               match your module's factions (repute.2da); wrong values can make the door hostile or
               unusable by the party.</string>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="label_42">
             <property name="text">
              <string>Animation State:</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QSpinBox" name="animationState">
             <property name="toolTip">
              <string>Animation State (GFF: AnimationState). BYTE 0–255. Current door animation
               state (e.g. open/closed). CSWSDoor::LoadDoor does not read this field in the template
               loader; it may be used when loading from save or for instance state in the area. In
               template UTDs leave at 0; runtime state is stored in the GIT for placed instances.
               Modders: set 0 for new doors.</string>
             </property>
             <property name="minimumSize">
              <size>
               <width>0</width>
               <height>25</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>255</number>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QWidget" name="widget_4" native="true">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Preferred" vsizetype="MinimumExpanding">
            <horstretch>0</horstretch>
            <verstretch>0</verstretch>
           </sizepolicy>
          </property>
          <layout class="QFormLayout" name="statsLayout">
           <item row="0" column="0">
            <widget class="QLabel" name="label_3">
             <property name="text">
              <string>Current HP:</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QSpinBox" name="currentHpSpin">
             <property name="toolTip">
              <string>Current HP (GFF: CurrentHP). SHORT. Door's current hit points when loaded;
               when it reaches 0 the door is destroyed and OnDeath runs. Engine reads via
               ReadFieldSHORT in LoadDoor. Modders: valid range 0–32767; usually set equal to Max HP
               for a full-strength door. Clamped to Max HP when loading from GIT if a flag is set.</string>
             </property>
             <property name="minimumSize">
              <size>
               <width>30</width>
               <height>25</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>32767</number>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="label_26">
             <property name="text">
              <string>Max HP:</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QSpinBox" name="maxHpSpin">
             <property name="toolTip">
              <string>Max HP (GFF: HP). SHORT. Maximum hit points; door is destroyed when Current HP
               reaches 0. Engine reads via ReadFieldSHORT in LoadDoor. Modders: valid range 0–32767;
               typical values 10–50 for breakable doors. Plot or Static doors may ignore damage.</string>
             </property>
             <property name="minimumSize">
              <size>
               <width>0</width>
               <height>25</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>32767</number>
             </property>
            </widget>
           </item>
           <item row="2" column="0">
            <widget class="QLabel" name="label_20">
             <property name="text">
              <string>Hardness:</string>
             </property>
            </widget>
           </item>
           <item row="2" column="1">
            <widget class="QSpinBox" name="hardnessSpin">
             <property name="toolTip">
              <string>Hardness (GFF: Hardness). BYTE. Damage reduction applied when the door is hit;
               reduces each attack's damage. Engine reads via ReadFieldBYTE in LoadDoor (default 0).
               Modders: valid range 0–255; typical 0–20. Does not prevent destruction when HP
               reaches 0.</string>
             </property>
             <property name="minimumSize">
              <size>
               <width>0</width>
               <height>25</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>255</number>
             </property>
            </widget>
           </item>
           <item row="3" column="0">
            <widget class="QLabel" name="label_21">
             <property name="text">
              <string>Fortitude:</string>
             </property>
            </widget>
           </item>
           <item row="3" column="1">
            <widget class="QSpinBox" name="fortitudeSpin">
             <property name="toolTip">
              <string>Fortitude (GFF: Fort). BYTE. Fortitude save value for the door; used in some
               save checks (e.g. against spells). Engine reads via ReadFieldBYTE in LoadDoor.
               Modders: valid range 0–255; often 0 in vanilla files.</string>
             </property>
             <property name="minimumSize">
              <size>
               <width>0</width>
               <height>25</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>255</number>
             </property>
            </widget>
           </item>
           <item row="4" column="0">
            <widget class="QLabel" name="label_24">
             <property name="text">
              <string>Reflex:</string>
             </property>
            </widget>
           </item>
           <item row="4" column="1">
            <widget class="QSpinBox" name="reflexSpin">
             <property name="toolTip">
              <string>Reflex (GFF: Ref). BYTE. Reflex save value for the door; used in some save
               checks. Engine reads via ReadFieldBYTE in LoadDoor. Modders: valid range 0–255; often
               0 in vanilla files.</string>
             </property>
             <property name="minimumSize">
              <size>
               <width>0</width>
               <height>25</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>255</number>
             </property>
            </widget>
           </item>
           <item row="5" column="0">
            <widget class="QLabel" name="label_25">
             <property name="text">
              <string>Will:</string>
             </property>
            </widget>
           </item>
           <item row="5" column="1">
            <widget class="QSpinBox" name="willSpin">
             <property name="toolTip">
              <string>Will (GFF: Will). BYTE. Will save value for the door; used in some save checks
               (e.g. against mind-affecting effects). Engine reads via ReadFieldBYTE in LoadDoor.
               Modders: valid range 0–255; often 0 in vanilla files.</string>
             </property>
             <property name="minimumSize">
              <size>
               <width>0</width>
               <height>25</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>255</number>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab">
       <attribute name="title">
        <string>Lock</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_5">
        <item>
         <widget class="QGroupBox" name="groupBox_3">
          <property name="title">
           <string>Key</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_4">
           <item>
            <widget class="QCheckBox" name="needKeyCheckbox">
             <property name="toolTip">
              <string>Key Required (GFF: KeyRequired). BYTE 0/1. When set, the door is locked until
               the player uses an item whose tag matches Key Tag. Engine reads via ReadFieldBYTE in
               LoadDoor. Modders: enable and set Key Tag to the tag of the key item (e.g. a UTI in
               the module).</string>
             </property>
             <property name="text">
              <string>Key required to unlock</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QCheckBox" name="removeKeyCheckbox">
             <property name="toolTip">
              <string>Remove Key on Unlock (GFF: AutoRemoveKey). BYTE 0/1. When set, the key item is
               consumed (removed from inventory) when used to unlock the door. Engine reads via
               ReadFieldBYTE in LoadDoor. Modders: enable for one-use keys; disable if the key
               should remain in inventory.</string>
             </property>
             <property name="text">
              <string>Remove key on unlock</string>
             </property>
            </widget>
           </item>
           <item>
            <layout class="QHBoxLayout" name="horizontalLayout">
             <item>
              <widget class="QLabel" name="label_4">
               <property name="text">
                <string>Key Tag:</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QLineEdit" name="keyEdit">
               <property name="toolTip">
                <string>Key Tag (GFF: KeyName). CExoString. Tag of the key item required to unlock
                 the door when Key Required is set. The player must have an item in inventory whose
                 tag matches this string. Engine reads via ReadFieldCExoString in LoadDoor. Modders:
                 use the same tag as the key UTI's Tag field.</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_2">
          <property name="title">
           <string>Lock</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_3">
           <item>
            <layout class="QVBoxLayout" name="verticalLayout_2">
             <item>
              <widget class="QCheckBox" name="lockedCheckbox">
               <property name="toolTip">
                <string>Locked (GFF: Locked). BYTE 0/1. When set, the door starts locked; the player
                 must use a matching key or pick the lock (Open Lock DC) to open it. Modders: enable
                 for doors that should start locked; combine with Key Required and Key Tag for
                 key-only doors.</string>
               </property>
               <property name="text">
                <string>Locked</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <layout class="QFormLayout" name="formLayout">
             <item row="0" column="0">
              <widget class="QLabel" name="label_2">
               <property name="text">
                <string>Open Lock DC:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="difficultyLabel">
               <property name="text">
                <string>Difficulty:</string>
               </property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="difficultyModLabel">
               <property name="text">
                <string>Difficulty Mod:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QSpinBox" name="openLockSpin">
               <property name="toolTip">
                <string>Open Lock DC (GFF: OpenLockDC). BYTE. Difficulty class to pick the lock
                 (Security check). Engine reads via ReadFieldBYTE in LoadDoor. Modders: valid range
                 0–255; typical 5–25. Use 0 for unlocked or non-lockable doors. Key Required
                 overrides this when the key is used.</string>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QSpinBox" name="difficultySpin">
               <property name="toolTip">
                <string>Difficulty (GFF: OpenLockDiff). KotOR 2 only. Additional difficulty value
                 for lock picking. Modders: valid range 0–255; only used in TSL. Leave 0 if
                 targeting K1.</string>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="QSpinBox" name="difficultyModSpin">
               <property name="toolTip">
                <string>Difficulty Mod (GFF: OpenLockDiffMod). KotOR 2 only. INT8 (-128 to 127).
                 Modifier added to Open Lock DC when calculating lock pick difficulty; positive
                 values make the lock harder, negative values make it easier. Engine reads via
                 ReadField in TSL LoadDoor. Modders: use 0 for default; positive for tougher locks,
                 negative to soften difficulty. Leave 0 if targeting K1.</string>
               </property>
               <property name="minimum">
                <number>-128</number>
               </property>
               <property name="maximum">
                <number>127</number>
               </property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <spacer name="verticalSpacer">
             <property name="orientation">
              <enum>Qt::Vertical</enum>
             </property>
             <property name="sizeHint" stdset="0">
              <size>
               <width>20</width>
               <height>40</height>
              </size>
             </property>
            </spacer>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_2">
       <attribute name="title">
        <string>Scripts</string>
       </attribute>
       <layout class="QFormLayout" name="formLayout_2">
        <item row="0" column="0">
         <widget class="QLabel" name="label_18">
          <property name="text">
           <string>OnClicked:</string>
          </property>
         </widget>
        </item>
        <item row="0" column="1">
         <widget class="FilterComboBox" name="onClickEdit">
          <property name="toolTip">
           <string>OnClicked (GFF: OnClick). ResRef of NCS script (max 16 chars). Fires when the
            player clicks the door. Leave blank for no script. Modders: use for custom door
            interaction or dialogue triggers.</string>
          </property>
         </widget>
        </item>
        <item row="1" column="0">
         <widget class="QLabel" name="label_5">
          <property name="text">
           <string>OnClosed:</string>
          </property>
         </widget>
        </item>
        <item row="1" column="1">
         <widget class="FilterComboBox" name="onClosedEdit">
          <property name="toolTip">
           <string>OnClosed (GFF: OnClosed). ResRef of NCS script. Fires when the door closes.
            Engine reads via ReadFieldCResRef in LoadDoor. Leave blank for no script. Max 16
            characters.</string>
          </property>
         </widget>
        </item>
        <item row="2" column="0">
         <widget class="QLabel" name="label_7">
          <property name="text">
           <string>OnDamaged:</string>
          </property>
         </widget>
        </item>
        <item row="2" column="1">
         <widget class="FilterComboBox" name="onDamagedEdit">
          <property name="toolTip">
           <string>OnDamaged (GFF: OnDamaged). ResRef of NCS script. Fires when the door takes
            damage. Engine reads via ReadFieldCResRef in LoadDoor. Leave blank for no script. Max 16
            characters.</string>
          </property>
         </widget>
        </item>
        <item row="3" column="0">
         <widget class="QLabel" name="label_8">
          <property name="text">
           <string>OnDeath:</string>
          </property>
         </widget>
        </item>
        <item row="3" column="1">
         <widget class="FilterComboBox" name="onDeathEdit">
          <property name="toolTip">
           <string>OnDeath (GFF: OnDeath). ResRef of NCS script. Fires when the door is destroyed
            (HP reaches 0). Engine reads via ReadFieldCResRef in LoadDoor. Leave blank for no
            script. Max 16 characters.</string>
          </property>
         </widget>
        </item>
        <item row="4" column="0">
         <widget class="QLabel" name="label_10">
          <property name="text">
           <string>OnOpenFailed:</string>
          </property>
         </widget>
        </item>
        <item row="4" column="1">
         <widget class="FilterComboBox" name="onOpenFailedEdit">
          <property name="toolTip">
           <string>OnOpenFailed. ResRef of NCS script. Fires when the player fails to open the door
            (e.g. failed lock pick). Leave blank for no script. Max 16 characters.</string>
          </property>
         </widget>
        </item>
        <item row="5" column="0">
         <widget class="QLabel" name="label_11">
          <property name="text">
           <string>OnHeartbeat:</string>
          </property>
         </widget>
        </item>
        <item row="5" column="1">
         <widget class="FilterComboBox" name="onHeartbeatSelect">
          <property name="toolTip">
           <string>OnHeartbeat (GFF: OnHeartbeat). ResRef of NCS script. Fires periodically while
            the door is in the area. Engine reads via ReadFieldCResRef in LoadDoor. Leave blank for
            no script. Max 16 characters.</string>
          </property>
         </widget>
        </item>
        <item row="6" column="0">
         <widget class="QLabel" name="label_13">
          <property name="text">
           <string>OnMeleeAttack:</string>
          </property>
         </widget>
        </item>
        <item row="6" column="1">
         <widget class="FilterComboBox" name="onMeleeAttackEdit">
          <property name="toolTip">
           <string>OnMeleeAttack. ResRef of NCS script. Fires when the door is melee-attacked. Leave
            blank for no script. Max 16 characters.</string>
          </property>
         </widget>
        </item>
        <item row="7" column="0">
         <widget class="QLabel" name="label_16">
          <property name="text">
           <string>OnSpellCastAt:</string>
          </property>
         </widget>
        </item>
        <item row="7" column="1">
         <widget class="FilterComboBox" name="onSpellEdit">
          <property name="toolTip">
           <string>OnSpellCastAt (GFF: OnSpellCastAt). ResRef of NCS script. Fires when a spell is
            cast at the door. Leave blank for no script. Max 16 characters.</string>
          </property>
         </widget>
        </item>
        <item row="8" column="0">
         <widget class="QLabel" name="label_17">
          <property name="text">
           <string>OnOpen:</string>
          </property>
         </widget>
        </item>
        <item row="8" column="1">
         <widget class="FilterComboBox" name="onOpenEdit">
          <property name="toolTip">
           <string>OnOpen. ResRef of NCS script. Fires when the door is opened. Leave blank for no
            script. Max 16 characters.</string>
          </property>
         </widget>
        </item>
        <item row="9" column="0">
         <widget class="QLabel" name="label_23">
          <property name="text">
           <string>OnUnlock:</string>
          </property>
         </widget>
        </item>
        <item row="9" column="1">
         <widget class="FilterComboBox" name="onUnlockEdit">
          <property name="toolTip">
           <string>OnUnlock. ResRef of NCS script. Fires when the door is unlocked (key or lock
            pick). Leave blank for no script. Max 16 characters.</string>
          </property>
         </widget>
        </item>
        <item row="10" column="0">
         <widget class="QLabel" name="label_19">
          <property name="text">
           <string>OnUserDefined:</string>
          </property>
         </widget>
        </item>
        <item row="10" column="1">
         <widget class="FilterComboBox" name="onUserDefinedSelect">
          <property name="toolTip">
           <string>OnUserDefined (GFF: ScriptUserDefine). ResRef of NCS script. Fires when another
            script calls ExecuteScript with this door and the user-defined event. Leave blank for no
            script. Max 16 characters.</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="commentsTab">
       <attribute name="title">
        <string>Comments</string>
       </attribute>
       <layout class="QGridLayout" name="gridLayout_4">
        <item row="0" column="0">
         <widget class="QPlainTextEdit" name="commentsEdit">
          <property name="toolTip">
           <string>Comments (GFF: Comment). CExoString. Developer notes only—the game never reads or
            displays this. Use it to document the door (e.g. purpose, author, change log). Modders:
            add notes for yourself or your team.</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>
