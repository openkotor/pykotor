          <width>300</width>
          <height>0</height>
         </size>
        </property>
        <property name="mouseTracking">
         <bool>true</bool>
        </property>
        <property name="focusPolicy">
         <enum>Qt::StrongFocus</enum>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QGroupBox" name="modelInfoGroupBox">
        <property name="toolTip">
         <string>Model information panel. Expand to see details about the door model (mesh count,
          animations, etc.) derived from the Appearance and game resources. Read-only; does not
          change the UTD file. Useful to verify the correct model loads for the chosen Appearance.</string>
        </property>
        <property name="title">
         <string>Model Info</string>
        </property>
        <property name="checkable">
         <bool>true</bool>
        </property>
        <property name="checked">
         <bool>false</bool>
        </property>
        <property name="sizePolicy">
         <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
          <horstretch>0</horstretch>
          <verstretch>0</verstretch>
         </sizepolicy>
        </property>
        <layout class="QVBoxLayout" name="verticalLayout_modelInfo">
         <item>
          <widget class="QLabel" name="modelInfoSummaryLabel">
           <property name="toolTip">
            <string>Short summary of the door model (e.g. mesh and animation count). Click the Model
             Info group to expand and see full details. Derived from the current Appearance; not a
             GFF field.</string>
           </property>
           <property name="sizePolicy">
            <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
             <horstretch>0</horstretch>
             <verstretch>0</verstretch>
