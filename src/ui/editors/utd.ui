              <horstretch>1</horstretch>
              <verstretch>0</verstretch>
             </sizepolicy>
            </property>
            <property name="text">
             <string>Tag:</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_16">
            <item>
             <widget class="QLineEdit" name="tagEdit">
              <property name="toolTip">
               <string>Tag (GFF: Tag). CExoString. Unique identifier for this door; scripts and
                dialogues use GetObjectByTag to find it. Engine reads via ReadFieldCExoString in
                LoadDoor. Modders: keep unique per module; use a descriptive tag (e.g.
                "tar_maze_door").</string>
              </property>
              <property name="sizePolicy">
               <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                <horstretch>0</horstretch>
                <verstretch>0</verstretch>
               </sizepolicy>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="tagGenerateButton">
              <property name="toolTip">
               <string>Generate tag from ResRef. Copies the Template ResRef into the Tag field so
                they stay in sync. Scripts reference doors by Tag; keep Tag unique per module.</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>30</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="2" column="0">
           <widget class="QLabel" name="label_38">
            <property name="sizePolicy">
             <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
              <horstretch>1</horstretch>
              <verstretch>0</verstretch>
             </sizepolicy>
            </property>
            <property name="text">
             <string>ResRef:</string>
            </property>
           </widget>
          </item>
          <item row="2" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_17">
            <item>
             <widget class="QLineEdit" name="resrefEdit">
              <property name="toolTip">
               <string>Template ResRef (GFF: TemplateResRef). ResRef (max 16 characters) identifying
                this door template. The engine stores ResRefs in a 16-byte structure. When the game
                loads a door from a GIT file it uses this to find the UTD template. Modders: set to
                match the UTD filename (without .utd); keep under 16 characters.</string>
              </property>
              <property name="sizePolicy">
               <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                <horstretch>0</horstretch>
                <verstretch>0</verstretch>
               </sizepolicy>
              </property>
              <property name="maxLength">
               <number>16</number>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="resrefGenerateButton">
              <property name="toolTip">
               <string>Generate ResRef from Tag. Copies the Tag into the Template ResRef field (max
                16 characters). ResRef should match the UTD filename.</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>30</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="3" column="0">
           <widget class="QLabel" name="label_15">
            <property name="sizePolicy">
             <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
              <horstretch>1</horstretch>
              <verstretch>0</verstretch>
             </sizepolicy>
            </property>
            <property name="text">
             <string>Appearance:</string>
            </property>
           </widget>
          </item>
          <item row="3" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_18">
            <item>
             <widget class="ComboBox2DA" name="appearanceSelect">
              <property name="toolTip">
               <string>Appearance (GFF: Appearance). DWORD read as byte in LoadDoor—index into
                doortypes.2da or genericdoors.2da. Picks the 3D model and behavior of the door.
                Modders: choose a row that exists in the door 2DA for your game; invalid indices may
                show a wrong or missing model.</string>
              </property>
              <property name="sizePolicy">
               <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                <horstretch>0</horstretch>
                <verstretch>0</verstretch>
               </sizepolicy>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="4" column="0">
           <widget class="QLabel" name="label">
            <property name="sizePolicy">
             <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
              <horstretch>1</horstretch>
              <verstretch>0</verstretch>
             </sizepolicy>
            </property>
            <property name="text">
             <string>Conversation:</string>
            </property>
           </widget>
          </item>
          <item row="4" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_5">
            <item>
             <widget class="FilterComboBox" name="conversationEdit">
              <property name="toolTip">
               <string>Conversation (GFF: Conversation). ResRef of the dialogue (DLG) file; max 16
                characters. When the player uses this door the game can run this dialogue. Blank
                means no dialogue. Engine reads via ReadFieldCResRef in LoadDoor. Modders: set to a
                DLG resref; use Edit to open the dialogue editor.</string>
              </property>
              <property name="sizePolicy">
               <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                <horstretch>1</horstretch>
                <verstretch>0</verstretch>
               </sizepolicy>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="conversationModifyButton">
              <property name="toolTip">
               <string>Open the dialogue editor for the Conversation (DLG) assigned to this door.</string>
              </property>
              <property name="sizePolicy">
               <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                <horstretch>0</horstretch>
                <verstretch>0</verstretch>
               </sizepolicy>
              </property>
              <property name="text">
               <string>Edit</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
