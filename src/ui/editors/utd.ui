    <item>
     <layout class="QVBoxLayout" name="verticalLayout_preview">
      <item>
       <widget class="ModelRenderer" name="previewRenderer">
        <property name="toolTip">
         <string>Door model preview. Displays the 3D model for the selected Appearance (Generic
          Doors 2DA row). The game uses the same appearance index when loading the door in-game.
          Drag to rotate; use the Appearance dropdown to change which door model is shown. Not a GFF
          field—purely for visual feedback in the editor.</string>
        </property>
        <property name="sizePolicy">
         <sizepolicy hsizetype="Preferred" vsizetype="Expanding">
          <horstretch>0</horstretch>
          <verstretch>0</verstretch>
         </sizepolicy>
        </property>
        <property name="minimumSize">
