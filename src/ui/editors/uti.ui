        </item>
        <item>
         <layout class="QFormLayout" name="formLayout">
          <item row="0" column="0">
           <widget class="QLabel" name="nameLabel">
            <property name="text">
             <string>Name:</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_18">
            <item>
             <widget class="LocalizedStringLineEdit" name="nameEdit" native="true">
              <property name="minimumSize">
               <size>
                <width>0</width>
                <height>23</height>
               </size>
              </property>
              <property name="toolTip">
               <string>Name (GFF: LocalizedName). CExoLocString. The displayed name of the item in
                inventory, stores, and dialogue. Engine reads via ReadFieldCExoLocString in
                CSWSItem::LoadDataFromGff. Modders: set a custom name or leave
                empty to use the base item's default from baseitems.2da. Shown in the item
                description panel and store/container UI.</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="tagLabel">
            <property name="text">
             <string>Tag:</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_19">
            <item>
             <widget class="QLineEdit" name="tagEdit">
              <property name="toolTip">
               <string>Tag (GFF: Tag). CExoString. Unique identifier for this item when placed in
                the module. Engine reads via ReadFieldCExoString in LoadDataFromGff. Scripts use
                GetItemByTag to target this item. Modders: leave blank for
                stackable/generic items; set a tag for scripted references. Duplicate tags in the
                same area can cause wrong item to be targeted.</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="tagGenerateButton">
              <property name="toolTip">
               <string>Generate tag from ResRef. Copies the Template ResRef into the Tag field so
                they stay in sync. Use when you need to reference this item by tag in scripts; keep
                Tag unique per area.</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>26</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="2" column="0">
           <widget class="QLabel" name="resrefLabel">
            <property name="text">
             <string>ResRef:</string>
            </property>
           </widget>
          </item>
          <item row="2" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_20">
            <item>
             <widget class="QLineEdit" name="resrefEdit">
              <property name="maxLength">
               <number>16</number>
              </property>
              <property name="toolTip">
               <string>Template ResRef (GFF: TemplateResRef). ResRef (max 16 characters) of this
                item template; .uti extension implied. The engine stores ResRefs in 16 bytes. When
                the game loads an item it uses this to find the UTI
                file. Modders: must match the .uti filename; used by stores, loot tables, and
                GiveItem. Mismatch can cause missing or wrong item data.</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="resrefGenerateButton">
              <property name="toolTip">
               <string>Generate ResRef from Tag. Copies the Tag into the Template ResRef field (max
                16 characters). ResRef should match the UTI filename for the game to load the item
                correctly.</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>26</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="3" column="0">
           <widget class="QLabel" name="descriptionLabel">
            <property name="text">
             <string>Description:</string>
            </property>
           </widget>
          </item>
          <item row="3" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_21">
            <item>
             <widget class="LocalizedStringLineEdit" name="descEdit" native="true">
              <property name="minimumSize">
               <size>
                <width>0</width>
                <height>23</height>
               </size>
              </property>
              <property name="toolTip">
               <string>Description (GFF: DescIdentified). CExoLocString. Shown when the player
                examines an identified item. Engine reads via ReadFieldCExoLocString in
                LoadDataFromGff. "Description" (unidentified) is also read;
                DescIdentified is the main one shown after identification. Modders: use for lore,
                usage hints, or flavor text.</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="4" column="0">
           <widget class="QLabel" name="baseItemLabel">
            <property name="text">
             <string>Base Item:</string>
            </property>
           </widget>
          </item>
          <item row="4" column="1">
           <widget class="ComboBox2DA" name="baseSelect">
            <property name="toolTip">
             <string>Base Item (GFF: BaseItem). INT32. Engine reads via ReadFieldINT in
              LoadDataFromGff. Row index into baseitems.2da; determines category
              (weapon, armor, usable), equip slots, model type, and default stats. Modders: must be
              a valid row; invalid indices can cause load failures or wrong visuals. Changing this
              changes the item's core behavior (e.g. blaster vs. lightsaber).</string>
            </property>
           </widget>
          </item>
          <item row="5" column="0">
           <widget class="QLabel" name="costLabel">
            <property name="text">
             <string>Cost:</string>
            </property>
           </widget>
          </item>
          <item row="5" column="1">
           <widget class="QSpinBox" name="costSpin">
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>2147483647</number>
            </property>
            <property name="toolTip">
             <string>Cost (GFF: Cost). Base sale/purchase price in credits. Stored as DWORD
              (0–4294967295); UI caps at 2147483647. The engine does not read this field in
              LoadDataFromGff; it is written by SaveItem when saving. Store and
              barter typically use base item pricing plus AddCost (which the engine does read).
              Modders: set for toolset consistency and documentation; to affect in-game price, use
              Additional Cost. 0 = free. Very high values may display oddly in some UIs.</string>
            </property>
           </widget>
          </item>
          <item row="6" column="0">
           <widget class="QLabel" name="addCostLabel">
            <property name="text">
             <string>Additional Cost:</string>
            </property>
           </widget>
          </item>
          <item row="6" column="1">
           <widget class="QSpinBox" name="additionalCostSpin">
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>2147483647</number>
            </property>
            <property name="toolTip">
             <string>Additional Cost (GFF: AddCost). DWORD. Engine reads via ReadFieldDWORD in
              LoadDataFromGff. Extra credits added to base cost; combined with
              base item pricing for final store price. Modders: increase for upgraded or
              high-property items. Valid range 0–4294967295; UI caps at 2147483647.</string>
            </property>
           </widget>
          </item>
          <item row="7" column="0">
           <widget class="QLabel" name="upgradeLvlLabel">
            <property name="text">
             <string>Upgrade Level:</string>
            </property>
           </widget>
          </item>
          <item row="7" column="1">
           <widget class="QSpinBox" name="upgradeSpin">
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>255</number>
            </property>
            <property name="toolTip">
             <string>Upgrade Level (GFF: Upgrades). DWORD in engine (ReadFieldDWORD in
              LoadDataFromGff). K1: bitfield for which upgrade slots are filled.
              K2: often used as upgrade tier (0–255). UI shows 0–255. Modders: must match base item;
              invalid values can break upgrade slots or display.</string>
            </property>
           </widget>
          </item>
          <item row="8" column="0">
           <widget class="QLabel" name="labelPlot">
            <property name="text">
             <string>Plot:</string>
            </property>
           </widget>
          </item>
          <item row="8" column="1">
           <widget class="QCheckBox" name="plotCheckbox">
            <property name="toolTip">
             <string>Plot (GFF: Plot). Boolean. If set, the item cannot be dropped or sold. Engine
              reads via ReadFieldCExoString/BOOL in LoadDataFromGff. Used for key quest items.</string>
            </property>
            <property name="text">
             <string />
            </property>
           </widget>
          </item>
          <item row="9" column="0">
           <widget class="QLabel" name="labelCharges">
            <property name="text">
             <string>Charges:</string>
            </property>
           </widget>
          </item>
          <item row="9" column="1">
           <widget class="QSpinBox" name="chargesSpin">
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>255</number>
            </property>
            <property name="toolTip">
             <string>Charges (GFF: Charges). Number of uses remaining for usable items (e.g.
              medpacs). Engine reads in LoadDataFromGff.</string>
            </property>
           </widget>
          </item>
          <item row="10" column="0">
           <widget class="QLabel" name="labelStack">
            <property name="text">
             <string>Stack Size:</string>
            </property>
           </widget>
          </item>
          <item row="10" column="1">
           <widget class="QSpinBox" name="stackSpin">
            <property name="minimum">
             <number>1</number>
            </property>
            <property name="maximum">
             <number>255</number>
            </property>
            <property name="toolTip">
             <string>Stack Size (GFF: StackSize). Number of items in this stack. Engine reads in
              LoadDataFromGff.</string>
            </property>
           </widget>
          </item>
          <item row="11" column="0">
           <widget class="QLabel" name="labelModelVar">
            <property name="text">
             <string>Model Variation:</string>
            </property>
           </widget>
          </item>
          <item row="11" column="1">
           <widget class="QSpinBox" name="modelVarSpin">
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>255</number>
            </property>
            <property name="toolTip">
             <string>Model Variation (GFF: ModelVariation). Picks which model variant is used for
              this base item. Affects 3D preview.</string>
            </property>
           </widget>
          </item>
          <item row="12" column="0">
           <widget class="QLabel" name="labelBodyVar">
            <property name="text">
             <string>Body Variation:</string>
            </property>
           </widget>
          </item>
          <item row="12" column="1">
           <widget class="QSpinBox" name="bodyVarSpin">
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>255</number>
            </property>
            <property name="toolTip">
             <string>Body Variation. Body part variant for the model.</string>
            </property>
           </widget>
          </item>
          <item row="13" column="0">
           <widget class="QLabel" name="labelTextureVar">
            <property name="text">
             <string>Texture Variation:</string>
            </property>
           </widget>
          </item>
          <item row="13" column="1">
           <widget class="QSpinBox" name="textureVarSpin">
            <property name="minimum">
             <number>0</number>
            </property>
            <property name="maximum">
             <number>255</number>
            </property>
            <property name="toolTip">
             <string>Texture Variation (GFF: TextureVar). Texture variant for the model. Affects 3D
              preview.</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_icon">
          <item>
           <widget class="QGroupBox" name="iconGroupBox">
            <property name="maximumSize">
             <size>
              <width>84</width>
              <height>16777215</height>
             </size>
            </property>
            <property name="title">
             <string>Icon</string>
            </property>
            <layout class="QGridLayout" name="gridLayout_icon">
             <property name="leftMargin">
              <number>3</number>
             </property>
             <property name="topMargin">
              <number>3</number>
             </property>
             <property name="rightMargin">
              <number>3</number>
             </property>
             <property name="bottomMargin">
              <number>3</number>
             </property>
             <property name="spacing">
              <number>3</number>
             </property>
             <item row="0" column="0">
              <widget class="QLabel" name="iconLabel">
               <property name="minimumSize">
                <size>
                 <width>64</width>
                 <height>64</height>
                </size>
               </property>
               <property name="maximumSize">
                <size>
                 <width>64</width>
                 <height>64</height>
                </size>
               </property>
               <property name="text">
                <string />
               </property>
               <property name="scaledContents">
                <bool>true</bool>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_2">
       <attribute name="title">
        <string>Properties</string>
       </attribute>
       <layout class="QHBoxLayout" name="horizontalLayout_2">
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_3">
          <item>
           <widget class="QLabel" name="availPropLabel">
            <property name="text">
             <string>Available Properties</string>
            </property>
            <property name="toolTip">
             <string>Available properties from itemprops.2da (and related 2DAs). Add properties to
              define enchantments, damage bonuses, and special effects. The engine reads assigned
              properties from GFF PropertiesList; each entry has PropertyName (WORD), Subtype
              (WORD),
              CostTable (BYTE), CostValue (WORD), Param1, Param1Value, ChanceAppear (BYTE), Useable
              (BYTE).
              Use the arrow buttons to assign.</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QTreeWidget" name="availablePropertyList">
            <attribute name="headerVisible">
             <bool>false</bool>
            </attribute>
            <column>
             <property name="text">
              <string notr="true">1</string>
             </property>
            </column>
           </widget>
          </item>
         </layout>
        </item>
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_2">
          <item>
           <spacer name="verticalSpacer">
            <property name="orientation">
             <enum>Qt::Vertical</enum>
            </property>
            <property name="sizeHint" stdset="0">
             <size>
              <width>20</width>
              <height>40</height>
             </size>
            </property>
           </spacer>
          </item>
          <item>
           <widget class="QPushButton" name="addPropertyButton">
            <property name="toolTip">
             <string>Add the selected available property to this item. Appends an entry to the GFF
              PropertiesList; the engine reads these in LoadDataFromGff. Use Edit
              Property to set Subtype, CostValue, Param1, Param1Value, ChanceAppear, etc.</string>
            </property>
            <property name="maximumSize">
             <size>
              <width>20</width>
              <height>16777215</height>
             </size>
            </property>
            <property name="text">
             <string>-&gt;</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="removePropertyButton">
            <property name="toolTip">
             <string>Remove the selected property from this item. Deletes the entry from the GFF
              PropertiesList. The item will no longer have that enchantment or effect in-game.</string>
            </property>
            <property name="maximumSize">
             <size>
              <width>20</width>
              <height>16777215</height>
             </size>
            </property>
            <property name="text">
             <string>&lt;-</string>
            </property>
           </widget>
          </item>
          <item>
           <spacer name="verticalSpacer_2">
            <property name="orientation">
             <enum>Qt::Vertical</enum>
            </property>
            <property name="sizeHint" stdset="0">
             <size>
              <width>20</width>
              <height>40</height>
             </size>
            </property>
           </spacer>
          </item>
         </layout>
        </item>
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_4">
          <item>
           <widget class="QLabel" name="propertyLabel">
            <property name="text">
             <string>Assigned Properties</string>
            </property>
            <property name="toolTip">
             <string>Assigned properties (GFF: PropertiesList). The engine reads this list in
              LoadDataFromGff via GetList("PropertiesList"); each element has
              PropertyName (WORD), Subtype (WORD), CostTable (BYTE), CostValue (WORD), Param1,
              Param1Value (BYTE), ChanceAppear (BYTE), Useable (BYTE). Edit Property to adjust
              values. Order can affect display and some game logic.</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QListWidget" name="assignedPropertiesList">
            <property name="toolTip">
             <string>List of item properties on this item. Each row is one entry in GFF
              PropertiesList. Select a row and click Edit Property to change Subtype, CostValue,
              Param1, Param1Value, ChanceAppear, and other fields. The game applies these effects
              when the item is equipped or used.</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="editPropertyButton">
            <property name="toolTip">
             <string>Open the property editor for the selected assigned property. Lets you set
              Subtype, CostTable, CostValue, Param1, Param1Value, ChanceAppear (0–100), Useable, and
              other fields. Required for configuring damage types, bonuses, and effect parameters.</string>
            </property>
            <property name="text">
             <string>Edit Property</string>
            </property>
           </widget>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="commentsTab">
       <attribute name="title">
        <string>Comments</string>
       </attribute>
       <layout class="QGridLayout" name="gridLayout_2">
        <item row="0" column="0">
         <widget class="QPlainTextEdit" name="commentsEdit">
          <property name="toolTip">
           <string>Comments (GFF: Comment). CExoString. Developer notes only—the game engine never
            reads or displays this. Use for mod documentation, credits, or internal notes. No length
            limit in GFF.</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>
