         <enum>Qt::StrongFocus</enum>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QGroupBox" name="modelInfoGroupBox">
        <property name="toolTip">
         <string>Model information panel. Expand to see details about the placeable model (mesh
          count, animations, etc.) derived from the Appearance and placeable.2da. Read-only; does
          not change the UTP file. Useful to verify the correct model loads for the chosen
          Appearance.</string>
        </property>
        <property name="title">
         <string>Model Info</string>
        </property>
        <property name="checkable">
         <bool>true</bool>
        </property>
        <property name="checked">
         <bool>false</bool>
        </property>
        <property name="sizePolicy">
         <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
          <horstretch>0</horstretch>
          <verstretch>0</verstretch>
