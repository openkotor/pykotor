      <widget class="QWidget" name="tab_9">
       <attribute name="title">
        <string>Basic</string>
       </attribute>
       <layout class="QGridLayout" name="gridLayout_3">
        <item row="1" column="0">
         <widget class="QGroupBox" name="groupBox_15">
          <property name="title">
           <string>Inventory</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_10">
           <item>
            <widget class="QCheckBox" name="hasInventoryCheckbox">
             <property name="toolTip">
              <string>Has Inventory (GFF: HasInventory). BYTE 0/1. Engine reads via ReadFieldBYTE in
               LoadPlaceable. When set (1), the placeable has a container inventory; the game loads
               ItemList when the player opens it. When unset (0), the placeable has no inventory and
               ItemList is ignored. Modders: enable for chests, crates, corpses; use Edit Inventory
               to add items (UTI ResRefs). Empty list is valid.</string>
             </property>
             <property name="text">
              <string>Has Inventory</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="inventoryButton">
             <property name="toolTip">
              <string>Opens the inventory editor for this placeable. The game loads ItemList when
               the placeable is opened (only if Has Inventory is set). Add or remove items; changes
               are written to the UTP GFF when you save.</string>
             </property>
             <property name="text">
              <string>Edit Inventory</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="inventoryCountLabel">
             <property name="toolTip">
              <string>Shows the number of items in this placeable's inventory (GFF ItemList). The
               game loads these items when the placeable is opened. Edit Inventory to add or remove
               items.</string>
             </property>
             <property name="enabled">
              <bool>false</bool>
             </property>
             <property name="text">
              <string>Total Items:</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item row="3" column="0">
         <spacer name="verticalSpacer">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>77</height>
           </size>
          </property>
         </spacer>
        </item>
        <item row="0" column="0">
         <widget class="QGroupBox" name="groupBox">
          <property name="title">
           <string>Profile</string>
          </property>
          <layout class="QGridLayout" name="gridLayout_2">
           <item row="0" column="0">
            <layout class="QFormLayout" name="formLayout_10">
             <item row="0" column="0">
              <widget class="QLabel" name="label_6">
               <property name="text">
                <string>Name:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_15">
               <item>
                <widget class="LocalizedStringLineEdit" name="nameEdit" native="true">
                 <property name="toolTip">
                  <string>Name (GFF: LocName). CExoLocString. Localized name shown when the player
                   examines or uses the placeable; the engine reads it in LoadPlaceable. Used in
                   tooltips and dialogue. Empty is valid. Modders: set a short, clear name (e.g.
                   "Crate", "Computer"); use the language selector to add translations. Does not
                   affect scripts—use Tag for that.</string>
                 </property>
                 <property name="minimumSize">
                  <size>
                   <width>0</width>
                   <height>23</height>
                  </size>
                 </property>
                </widget>
               </item>
              </layout>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_14">
               <property name="text">
                <string>Tag:</string>
               </property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="label_38">
               <property name="text">
                <string>ResRef:</string>
               </property>
              </widget>
             </item>
             <item row="3" column="0">
              <widget class="QLabel" name="label_15">
               <property name="text">
                <string>Appearance:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_16">
               <item>
                <widget class="QLineEdit" name="tagEdit">
                 <property name="toolTip">
                  <string>Tag (GFF: Tag). CExoString. Unique identifier for this placeable. The
                   engine reads it via ReadFieldCExoString in LoadPlaceable. Scripts and dialogues
                   use GetObjectByTag to find this placeable (e.g. to open it, lock it, or run
                   scripts). Modders: keep unique per area; duplicate tags can cause the wrong
                   object to be targeted. Empty is valid but the placeable cannot be found by tag.
                   Match this to any script or dialogue references.</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="tagGenerateButton">
                 <property name="toolTip">
                  <string>Copy the Template ResRef into the Tag field so they stay in sync. Use when
                   you need to reference this placeable by tag in scripts; keep Tag unique per area.
                   Engine reads Tag via ReadFieldCExoString in LoadPlaceable.</string>
                 </property>
                 <property name="maximumSize">
                  <size>
                   <width>26</width>
                   <height>16777215</height>
                  </size>
                 </property>
                 <property name="text">
                  <string>-</string>
                 </property>
                </widget>
               </item>
              </layout>
             </item>
             <item row="2" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_17">
               <item>
                <widget class="QLineEdit" name="resrefEdit">
                 <property name="toolTip">
                  <string>Template ResRef (GFF: TemplateResRef). ResRef (max 16 characters) for this
                   placeable template. The engine stores ResRefs in 16 bytes. When the game loads a
                   placeable from a GIT it uses this to load the UTP. Modders: match the UTP
                   filename (without .utp); keep under 16 characters.</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                 <property name="maxLength">
                  <number>16</number>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="resrefGenerateButton">
                 <property name="toolTip">
                  <string>Copy the Tag into the Template ResRef field (max 16 characters). ResRef
                   should match the UTP filename so the game finds the template when loading
                   placeables from the GIT. Engine reads TemplateResRef via ReadFieldCResRef in
                   LoadPlaceable.</string>
                 </property>
                 <property name="maximumSize">
                  <size>
                   <width>26</width>
                   <height>16777215</height>
                  </size>
                 </property>
                 <property name="text">
                  <string>-</string>
                 </property>
                </widget>
               </item>
              </layout>
             </item>
             <item row="3" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_18">
               <item>
                <widget class="ComboBox2DA" name="appearanceSelect">
                 <property name="toolTip">
                  <string>Appearance (GFF: Appearance). DWORD. Engine reads via ReadFieldDWORD in
                   LoadPlaceable. Row index into placeable.2da; picks the 3D model and behavior. The
                   game uses this when the placeable is placed in an area. Modders: choose a row
                   that exists in placeable.2da for your game; invalid indices may show a wrong
                   model or fail to display. Preview updates when you change this.</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                </widget>
               </item>
               <item>
                <spacer name="horizontalSpacer_11">
                 <property name="orientation">
                  <enum>Qt::Horizontal</enum>
                 </property>
                 <property name="sizeType">
                  <enum>QSizePolicy::Fixed</enum>
                 </property>
                 <property name="sizeHint" stdset="0">
                  <size>
                   <width>29</width>
                   <height>17</height>
                  </size>
                 </property>
                </spacer>
               </item>
              </layout>
             </item>
             <item row="4" column="0">
              <widget class="QLabel" name="label">
               <property name="text">
                <string>Conversation:</string>
               </property>
              </widget>
             </item>
             <item row="4" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_5">
               <item>
                <widget class="FilterComboBox" name="conversationEdit">
                 <property name="toolTip">
                  <string>Conversation (GFF: Conversation). ResRef of the dialogue (DLG) file; max
                   16 characters. When the player uses the placeable (if Useable is set), the game
                   can run this dialogue. Blank means no dialogue. Modders: set a DLG resref and use
                   Edit to open the dialogue editor.</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="conversationModifyButton">
                 <property name="toolTip">
                  <string>Open the dialogue editor for the Conversation DLG. The game runs this
                   dialogue when the player uses the placeable (if Useable is set). Engine reads
                   Conversation via ReadFieldCResRef in LoadPlaceable. Leave
                   Conversation blank for no dialogue.</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                   <horstretch>1</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                 <property name="maximumSize">
                  <size>
                   <width>26</width>
                   <height>16777215</height>
                  </size>
                 </property>
                 <property name="text">
                  <string>Edit</string>
                 </property>
                </widget>
               </item>
              </layout>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="tab_10">
       <attribute name="title">
        <string>Advanced</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout">
        <item>
         <widget class="QGroupBox" name="groupBox_16">
          <property name="title">
           <string>Flags</string>
          </property>
          <layout class="QGridLayout" name="gridLayout_5">
           <item row="2" column="0">
            <widget class="QCheckBox" name="useableCheckbox">
             <property name="toolTip">
              <string>Useable (GFF: Useable). BYTE 0/1. When set, the placeable can be clicked/used
               by the player (runs Conversation or OnUsed script). When unset, the placeable cannot
               be directly interacted with. Modders: enable for containers, computers, and
               interactive objects; leave off for decoration.</string>
             </property>
             <property name="text">
              <string>Useable</string>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QCheckBox" name="partyInteractCheckbox">
             <property name="toolTip">
              <string>Party Interact (GFF: PartyInteract). BYTE 0/1. When set, any party member can
               use the placeable; when unset, only the player might be able to (engine-dependent).
               Modders: enable for shared containers or objects the whole party should use.</string>
             </property>
             <property name="text">
              <string>Party Interact</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QCheckBox" name="staticCheckbox">
             <property name="toolTip">
              <string>Static (GFF: Static). BYTE 0/1. When set, the placeable is non-interactive (no
               use, no dialogue). Used for decorative objects. Modders: enable for scenery; leave
               off for containers or useable objects.</string>
             </property>
             <property name="text">
              <string>Static</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QCheckBox" name="plotCheckbox">
             <property name="toolTip">
              <string>Plot (GFF: Plot). BYTE 0/1. When set, the placeable is plot-critical; the game
               may prevent it from being destroyed. Modders: enable for story-essential objects;
               leave off for normal destructible placeables.</string>
             </property>
             <property name="text">
              <string>Plot</string>
             </property>
            </widget>
           </item>
           <item row="2" column="1">
            <widget class="QCheckBox" name="notBlastableCheckbox">
             <property name="toolTip">
              <string>Not Blastable (GFF: NotBlastable). KotOR 2 only. BYTE 0/1. When set, the
               placeable cannot be destroyed by explosives. Modders: enable for placeables that must
               be opened or destroyed by script only.</string>
             </property>
             <property name="text">
              <string>Not Blastable</string>
             </property>
            </widget>
           </item>
           <item row="0" column="0">
            <widget class="QCheckBox" name="min1HpCheckbox">
             <property name="toolTip">
              <string>Min 1 HP (GFF: Min1HP). BYTE 0/1. When set, the placeable's HP cannot go below
               1 from damage. Scripts can still destroy it. Modders: use for placeables that must
               stay until scripted removal.</string>
             </property>
             <property name="text">
              <string>Min1HP</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_17">
          <property name="title">
           <string>Other</string>
          </property>
          <layout class="QFormLayout" name="formLayout_11">
           <item row="0" column="0">
            <widget class="QLabel" name="label_41">
             <property name="text">
              <string>Faction:</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="ComboBox2DA" name="factionSelect">
             <property name="toolTip">
              <string>Faction (GFF: Faction). DWORD. Engine reads via ReadFieldDWORD in
               LoadPlaceable. Faction identifier; determines who the placeable is hostile or
               friendly to (repute.2da). Modders: set to match your module's factions; 0 is often
               neutral. Wrong values can cause the placeable to be targeted by allies or ignored by
               enemies. Used for AI and combat targeting.</string>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="label_42">
             <property name="text">
              <string>Animation State:</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QSpinBox" name="animationState">
             <property name="toolTip">
              <string>Animation State (GFF: AnimationState). BYTE. Current placeable animation
               state. In engine files often 0. Modders: leave 0 in templates. Valid range 0–255.</string>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>255</number>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QFrame" name="frame_4">
          <property name="sizePolicy">
           <sizepolicy hsizetype="Preferred" vsizetype="MinimumExpanding">
            <horstretch>0</horstretch>
            <verstretch>0</verstretch>
           </sizepolicy>
          </property>
          <property name="minimumSize">
           <size>
            <width>0</width>
            <height>222</height>
           </size>
          </property>
          <layout class="QFormLayout" name="formLayout_3">
           <item row="0" column="0">
            <widget class="QLabel" name="label_3">
             <property name="text">
              <string>Current HP:</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QSpinBox" name="currentHpSpin">
             <property name="toolTip">
              <string>Current HP (GFF: CurrentHP). SHORT. Placeable's current hit points when
               loaded; when it reaches 0 the placeable is destroyed and OnDeath runs. Engine reads
               via ReadFieldSHORT in LoadPlaceable. Modders: valid range 0–32767; set equal to Max
               HP for full strength. Plot or Min1HP can prevent destruction; Static placeables may
               ignore damage. Clamped to Max HP when loading from GIT in some cases.</string>
             </property>
             <property name="sizePolicy">
              <sizepolicy hsizetype="Expanding" vsizetype="MinimumExpanding">
               <horstretch>0</horstretch>
               <verstretch>0</verstretch>
              </sizepolicy>
             </property>
             <property name="minimumSize">
              <size>
               <width>0</width>
               <height>30</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>32767</number>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="label_26">
             <property name="text">
              <string>Max HP:</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="QSpinBox" name="maxHpSpin">
             <property name="toolTip">
              <string>Max HP (GFF: HP). SHORT. Maximum hit points; the placeable is destroyed when
               Current HP reaches 0 (unless Plot or Min1HP). Engine reads via ReadFieldSHORT in
               LoadPlaceable. Modders: valid range 0–32767; typical 10–50 for breakable placeables.
               Use 0 or 1 for indestructible if combined with Plot. Healing and damage update
               Current HP at runtime.</string>
             </property>
             <property name="sizePolicy">
              <sizepolicy hsizetype="Minimum" vsizetype="MinimumExpanding">
               <horstretch>0</horstretch>
               <verstretch>0</verstretch>
              </sizepolicy>
             </property>
             <property name="minimumSize">
              <size>
               <width>0</width>
               <height>30</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>32767</number>
             </property>
            </widget>
           </item>
           <item row="2" column="0">
            <widget class="QLabel" name="label_20">
             <property name="text">
              <string>Hardness:</string>
             </property>
            </widget>
           </item>
           <item row="2" column="1">
            <widget class="QSpinBox" name="hardnessSpin">
             <property name="toolTip">
              <string>Hardness (GFF: Hardness). BYTE 0–255. Engine reads via ReadFieldBYTE in
               LoadPlaceable. Damage reduction applied when the placeable is hit; each attack's
               damage is reduced by this amount. Does not prevent destruction when HP reaches 0.
               Modders: typical 0–10; high values make the placeable very resistant to damage until
               HP is depleted.</string>
             </property>
             <property name="sizePolicy">
              <sizepolicy hsizetype="Minimum" vsizetype="MinimumExpanding">
               <horstretch>0</horstretch>
               <verstretch>0</verstretch>
              </sizepolicy>
             </property>
             <property name="minimumSize">
              <size>
               <width>0</width>
               <height>30</height>
              </size>
             </property>
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>255</number>
             </property>
            </widget>
           </item>
           <item row="3" column="0">
            <widget class="QLabel" name="label_21">
             <property name="text">
              <string>Fortitude:</string>
             </property>
            </widget>
           </item>
           <item row="3" column="1">
            <widget class="QSpinBox" name="fortitudeSpin">
             <property name="toolTip">
              <string>Fortitude (GFF: Fort). BYTE 0–255. Engine reads via ReadFieldBYTE in
               LoadPlaceable. Fortitude save value used in some save checks (e.g. spells, effects).
               Modders: often 0 in vanilla files; increase for placeables that must resist certain
               effects. Used with Reflex and Will for full save calculations.</string>
             </property>
             <property name="sizePolicy">
