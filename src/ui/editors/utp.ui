      <widget class="QWidget" name="tab">
       <attribute name="title">
        <string>Lock</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_5">
        <item>
         <widget class="QGroupBox" name="groupBox_3">
          <property name="title">
           <string>Key</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_4">
           <item>
            <widget class="QCheckBox" name="needKeyCheckbox">
             <property name="toolTip">
              <string>Key required (GFF: KeyRequired). BYTE 0/1. When set, the placeable can only be
               unlocked if the player has an item whose Tag matches the Key Tag below. Modders: set
               Key Tag to the item's Tag.</string>
             </property>
             <property name="text">
              <string>Key required to unlock</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QCheckBox" name="removeKeyCheckbox">
             <property name="toolTip">
              <string>Remove key on unlock (GFF: AutoRemoveKey). BYTE 0/1. When set, the key item is
               consumed when used to unlock. Modders: enable for one-time keys.</string>
             </property>
             <property name="text">
              <string>Remove key on unlock</string>
             </property>
            </widget>
           </item>
           <item>
            <layout class="QHBoxLayout" name="horizontalLayout">
             <item>
              <widget class="QLabel" name="label_4">
               <property name="text">
                <string>Key Tag:</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QLineEdit" name="keyEdit">
               <property name="toolTip">
                <string>Key Tag (GFF: KeyName). CExoString. Engine reads via ReadFieldCExoString in
                 LoadPlaceable. Tag of the key item required to unlock when Key Required is set. The
                 player must have an item in inventory whose Tag matches this string. Leave blank if
                 no key is required. Modders: use the same Tag as the key UTI's Tag field.
                 Case-sensitive in some engines.</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_2">
          <property name="title">
           <string>Lock</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_3">
           <item>
            <layout class="QVBoxLayout" name="verticalLayout_2">
             <item>
              <widget class="QCheckBox" name="lockedCheckbox">
               <property name="toolTip">
                <string>Locked (GFF: Locked). BYTE 0/1. When set, the placeable starts locked.
                 Player must use Security, a key, or a script to unlock. Modders: Lockable must be
                 set for locking to apply.</string>
               </property>
               <property name="text">
                <string>Locked</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <layout class="QFormLayout" name="formLayout">
             <item row="0" column="0">
              <widget class="QLabel" name="label_2">
               <property name="text">
                <string>Open Lock DC:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="difficultyLabel">
               <property name="text">
                <string>Difficulty:</string>
               </property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="difficultyModLabel">
               <property name="text">
                <string>Difficulty Mod:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QSpinBox" name="openLockSpin">
               <property name="toolTip">
                <string>Open Lock DC (GFF: OpenLockDC). BYTE 0–255. Engine reads via ReadFieldBYTE
                 in LoadPlaceable. Difficulty class for the Security check to pick the lock.
                 Modders: typical 10–25; 0 = trivial/unlocked. Key Required overrides this when the
                 player uses the matching key. Lockable must be set for the lock to apply.</string>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QSpinBox" name="difficultySpin">
               <property name="toolTip">
                <string>Difficulty (GFF: OpenLockDiff). KotOR 2 only. BYTE 0–255. Additional
                 difficulty value for lock picking; combined with Open Lock DC. Engine reads via
                 LoadPlaceable in TSL. Modders: use 0 for default; higher values make the lock
                 harder to pick. Leave 0 if targeting K1.</string>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="QSpinBox" name="difficultyModSpin">
               <property name="toolTip">
                <string>Difficulty Mod (GFF: OpenLockDiffMod). KotOR 2 only. Stored as signed byte
                 (-128 to 127). Modifier added to the effective Open Lock DC; positive = harder,
                 negative = easier. Modders: use 0 for default; leave 0 if targeting K1. Edge case:
                 combined DC can go below 0 (treated as 0) or above 255 (engine may clamp).</string>
               </property>
               <property name="minimum">
                <number>-128</number>
               </property>
               <property name="maximum">
                <number>127</number>
               </property>
              </widget>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
        <item>
