        </property>
        <layout class="QVBoxLayout" name="verticalLayout_modelInfo">
         <item>
          <widget class="QLabel" name="modelInfoSummaryLabel">
           <property name="toolTip">
            <string>Short summary of the placeable model (e.g. mesh and animation count). Click the
             Model Info group to expand and see full details. Derived from the current Appearance;
             not a GFF field.</string>
           </property>
           <property name="sizePolicy">
            <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
             <horstretch>0</horstretch>
