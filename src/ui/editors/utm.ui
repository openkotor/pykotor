  <widget class="QWidget" name="centralwidget">
   <layout class="QGridLayout" name="gridLayout">
    <item row="0" column="0">
     <widget class="QTabWidget" name="tabWidget">
      <property name="currentIndex">
       <number>0</number>
      </property>
      <widget class="QWidget" name="tab">
       <attribute name="title">
        <string>Basic</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_3">
        <item>
         <layout class="QFormLayout" name="formLayout">
          <item row="0" column="0">
           <widget class="QLabel" name="label_6">
            <property name="text">
             <string>Name:</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_18">
            <item>
             <widget class="LocalizedStringLineEdit" name="nameEdit" native="true">
              <property name="toolTip">
               <string>Name (GFF: LocName). CExoLocString. The display name shown in the
                merchant/store interface when the player opens the store. Engine reads via
                ReadFieldCExoLocString in CSWSStore::LoadStore. Default when missing: empty.
                In-game: shown at the top of the store UI. Modders: set a descriptive name (e.g.
                "Dantooine Merchant", "Czerka Corp"); use the game language for localization. Empty
                names may show as blank.</string>
              </property>
              <property name="minimumSize">
               <size>
                <width>0</width>
                <height>23</height>
               </size>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="label_14">
            <property name="text">
             <string>Tag:</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_19">
            <item>
             <widget class="QLineEdit" name="tagEdit">
              <property name="toolTip">
               <string>Tag (GFF: Tag). CExoString. Unique identifier for this merchant. Engine reads
                via ReadFieldCExoString in CSWSStore::LoadStore; default "". In-game: scripts use
                GetObjectByTag(sTag) to find the merchant (e.g. for OpenStore, dialogue conditions).
                Modders: keep unique per module so scripts target the correct store; set a
                descriptive tag (e.g. "dan_merchant"). Changing a tag breaks existing script
                references. Empty is valid but scripts cannot find this merchant.</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="tagGenerateButton">
              <property name="toolTip">
               <string>Generate Tag from ResRef. Copies the Template ResRef into the Tag field so
                they stay in sync. Use when you need to reference this merchant by tag in scripts
                (GetObjectByTag).</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>26</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="2" column="0">
           <widget class="QLabel" name="label_38">
            <property name="text">
             <string>ResRef:</string>
            </property>
           </widget>
          </item>
          <item row="2" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout_20">
            <item>
             <widget class="QLineEdit" name="resrefEdit">
              <property name="toolTip">
               <string>Template ResRef (GFF: ResRef). ResRef (max 16 characters); .utm extension
                implied. Identifies this merchant template file. When you place a store in an area
                (GIT StoreList), the toolset stores this ResRef so the game loads the correct UTM.
                LoadStore receives the struct from the loaded UTM file (via LoadFromTemplate).
                Modders: must match the .utm filename (without extension); keep under 16 characters.
                Mismatch can cause missing or wrong store data when loading the area.</string>
              </property>
              <property name="maxLength">
               <number>16</number>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="resrefGenerateButton">
              <property name="toolTip">
               <string>Generate ResRef from Tag. Copies the Tag into the Template ResRef field (max
                16 characters). ResRef must match the .utm filename for the game to load the
                template when placing stores in areas.</string>
              </property>
              <property name="maximumSize">
               <size>
                <width>26</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>-</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="3" column="0">
           <widget class="QLabel" name="label_39">
            <property name="text">
             <string>ID:</string>
            </property>
           </widget>
          </item>
          <item row="3" column="1">
           <layout class="QHBoxLayout" name="horizontalLayout">
            <item>
             <widget class="QSpinBox" name="idSpin">
              <property name="toolTip">
               <string>ID (GFF: ID). Toolset-only—the game engine never reads this. Used for
                organization in the toolset palette. Stored as BYTE (0–255) when saving; values
                outside 0–255 are truncated. Modders: leave at default or use for your own
                categorization. Has no effect on store behavior in-game.</string>
              </property>
              <property name="minimum">
               <number>0</number>
              </property>
              <property name="maximum">
               <number>255</number>
              </property>
             </widget>
            </item>
            <item>
             <spacer name="horizontalSpacer_3">
              <property name="orientation">
               <enum>Qt::Horizontal</enum>
              </property>
              <property name="sizeType">
               <enum>QSizePolicy::Fixed</enum>
              </property>
              <property name="sizeHint" stdset="0">
               <size>
                <width>29</width>
                <height>17</height>
               </size>
              </property>
             </spacer>
            </item>
           </layout>
          </item>
         </layout>
        </item>
        <item>
         <widget class="QPushButton" name="inventoryButton">
          <property name="toolTip">
           <string>Edit Inventory (GFF: ItemList). Opens the inventory editor for the merchant's
            ItemList. Add UTI ResRefs; set infinite stock or droppable per item. Engine loads via
            GetList/GetListElement; each element has InventoryRes (CResRef), Infinite (BYTE),
            ObjectId (DWORD). Changes are written to the UTM when you save. Empty list = merchant
            has no items until added at runtime.</string>
          </property>
          <property name="text">
           <string>Edit Inventory</string>
          </property>
         </widget>
        </item>
        <item>
         <layout class="QHBoxLayout" name="horizontalLayout_2" stretch="1,2">
          <item>
           <widget class="QGroupBox" name="groupBox">
            <property name="title">
             <string>Pricing</string>
            </property>
            <layout class="QFormLayout" name="formLayout_2">
             <item row="0" column="0">
              <widget class="QLabel" name="label">
               <property name="text">
                <string>Mark Up</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QSpinBox" name="markUpSpin">
               <property name="toolTip">
                <string>Mark Up (GFF: MarkUp). INT32. Engine reads via ReadFieldINT in
                 CSWSStore::LoadStore; default 0. Percentage multiplier for the selling price: 100 =
                 base item price; 150 = 50% markup; 200 = double price. In-game: applied when the
                 player buys items. Modders: typical 100–150; 0 may cause free or broken pricing.
                 Negative values can cause odd behavior.</string>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>2147483647</number>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_2">
               <property name="text">
                <string>Mark Down</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QSpinBox" name="markDownSpin">
               <property name="toolTip">
                <string>Mark Down (GFF: MarkDown). INT32. Engine reads via ReadFieldINT in
                 CSWSStore::LoadStore; default 0. Percentage of base item price the merchant pays
                 when the player sells: 100 = full price; 50 = half; 25 = quarter. In-game: applied
                 when the player sells items. Modders: typical 25–100; 0 may mean the merchant pays
                 nothing. Negative values can cause odd behavior.</string>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>2147483647</number>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <layout class="QVBoxLayout" name="verticalLayout_2">
            <item alignment="Qt::AlignVCenter">
             <widget class="QFrame" name="frame_2">
              <layout class="QFormLayout" name="formLayout_3">
               <item row="0" column="0">
                <widget class="QLabel" name="label_3">
                 <property name="text">
                  <string>OnOpenStore</string>
                 </property>
                </widget>
               </item>
               <item row="0" column="1">
                <widget class="QLineEdit" name="onOpenEdit">
                 <property name="toolTip">
                  <string>OnOpenStore (GFF: OnOpenStore). ResRef of NCS script (max 16 characters).
                   Engine reads via ReadFieldCResRef in CSWSStore::LoadStore. Fires when the player
                   opens the store—before the UI appears. In-game: use for custom logic,
                   restrictions, or dynamic inventory. Modders: leave blank for no script; script
                   runs in store context. Max 16 characters.</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                 <property name="maxLength">
                  <number>16</number>
                 </property>
                </widget>
               </item>
               <item row="1" column="0">
                <widget class="QLabel" name="label_4">
                 <property name="text">
                  <string>Store</string>
                 </property>
                </widget>
               </item>
               <item row="1" column="1">
                <widget class="QComboBox" name="storeFlagSelect">
                 <property name="toolTip">
                  <string>Store (GFF: BuySellFlag). BYTE. Engine reads via ReadFieldBYTE in
                   CSWSStore::LoadStore. Bit 0 = can buy from player; bit 1 = can sell to player.
                   Only Buy = bit 0; Only Sell = bit 1; Buy and Sell = both. In-game: restricts what
                   the player can do in the store UI. Modders: choose based on merchant role (e.g.
                   vendor = both; junk dealer = buy only).</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="MinimumExpanding" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                 <item>
                  <property name="text">
                   <string>Only Buy</string>
                  </property>
                 </item>
                 <item>
                  <property name="text">
                   <string>Only Sell</string>
                  </property>
                 </item>
                 <item>
                  <property name="text">
                   <string>Buy and Sell</string>
                  </property>
                 </item>
                </widget>
               </item>
              </layout>
             </widget>
            </item>
           </layout>
          </item>
         </layout>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="commentsTab">
       <attribute name="title">
        <string>Comments</string>
       </attribute>
       <layout class="QGridLayout" name="gridLayout_2">
        <item row="0" column="0">
         <widget class="QPlainTextEdit" name="commentsEdit">
          <property name="toolTip">
           <string>Comments (GFF: Comment). CExoString. Developer notes—the game never reads or
            displays this. Use for documentation, change logs, or notes for your team. Modders: no
            length limit in GFF; has no effect on store behavior in-game.</string>
          </property>
         </widget>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
