               <property name="toolTip">
                <string>Reflex save bonus (GFF: refbonus). Stored as SHORT; engine uses -128–127.
                 Flat bonus to Reflex saving throws (Dex-based). In-game: added to base save + Dex
                 modifier. Modders: 0 = no bonus; typical 0–10.</string>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="QSpinBox" name="willSpin">
               <property name="minimum">
                <number>-128</number>
               </property>
               <property name="maximum">
                <number>127</number>
