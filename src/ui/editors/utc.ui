      <widget class="QWidget" name="classesTab">
       <attribute name="title">
        <string>Classes</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_7">
        <item>
         <widget class="QGroupBox" name="groupBox_13">
          <property name="title">
           <string>Classes</string>
          </property>
          <layout class="QGridLayout" name="gridLayout_3">
           <item row="0" column="0">
            <layout class="QHBoxLayout" name="horizontalLayout_13" stretch="3,1,2">
             <item>
              <widget class="ComboBox2DA" name="class1Select">
               <property name="toolTip">
                <string>Class 1 (GFF: ClassList[0].Class). Index into classes.2da. The creature's
                 primary class (e.g. Soldier, Scout, Jedi Guardian). Determines BAB, saves, and
                 available feats. Modders: must pick a valid row; this plus Class 2 define the
                 creature's progression.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QSpinBox" name="class1LevelSpin">
               <property name="toolTip">
                <string>Class 1 Level (GFF: ClassList[0].ClassLevel). SHORT 0–32767. Level in the
                 first class; determines HP, BAB, saves, and skill points. The game uses this for
                 all level-based calculations. Modders: typical 1–20; must be at least 1 for a valid
                 class. Stored as signed 16-bit.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>32767</number>
               </property>
              </widget>
             </item>
             <item>
              <spacer name="horizontalSpacer_8">
               <property name="orientation">
                <enum>Qt::Horizontal</enum>
               </property>
               <property name="sizeHint" stdset="0">
                <size>
                 <width>40</width>
                 <height>20</height>
                </size>
               </property>
              </spacer>
             </item>
            </layout>
           </item>
           <item row="1" column="0">
            <layout class="QHBoxLayout" name="horizontalLayout_14" stretch="3,1,2">
             <item>
              <widget class="ComboBox2DA" name="class2Select">
               <property name="toolTip">
                <string>Class 2 (GFF: ClassList[1].Class). Index into classes.2da. Optional second
                 class for multiclassing. Choose [Unset] for single-class. Modders: multiclass uses
                 the higher BAB/save progression; both classes contribute to HP and skills.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QSpinBox" name="class2LevelSpin">
               <property name="toolTip">
                <string>Class 2 Level (GFF: ClassList[1].ClassLevel). SHORT 0–32767. Level in the
                 second class (multiclass). Use [Unset] in the class dropdown to have only one
                 class. Modders: typical 1–20; total levels (class1 + class2) drive BAB and saves.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>32767</number>
               </property>
              </widget>
             </item>
             <item>
              <spacer name="horizontalSpacer_9">
               <property name="orientation">
                <enum>Qt::Horizontal</enum>
               </property>
               <property name="sizeHint" stdset="0">
                <size>
                 <width>40</width>
                 <height>20</height>
                </size>
               </property>
              </spacer>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_12">
          <property name="title">
           <string>Alignment</string>
          </property>
          <layout class="QHBoxLayout" name="horizontalLayout_12">
           <item>
            <widget class="QLabel" name="label_52">
             <property name="text">
              <string>Dark</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QSlider" name="alignmentSlider">
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="toolTip">
              <string>Alignment (GFF: GoodEvil). 0 = Dark, 100 = Light. Stored as BYTE; the game
               clamps values over 100 down to 100. Affects portrait (light-side vs dark-side face),
               dialogue options, and story flags. Modders: 50 = neutral; 0 or 100 for full
               dark/light. Does not affect combat stats. Edge case: values above 100 in the GFF are
               clamped when loaded.</string>
             </property>
             <property name="value">
              <number>50</number>
             </property>
             <property name="orientation">
              <enum>Qt::Horizontal</enum>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QLabel" name="label_53">
             <property name="text">
              <string>Light</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <spacer name="spacer">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>0</width>
            <height>0</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="featsTab">
       <attribute name="title">
        <string>Feats</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_8" stretch="2,1">
        <item>
         <widget class="QListWidget" name="featList">
          <property name="toolTip">
           <string>Feat List (GFF: FeatList). Lists all feats granted to this creature. Each entry
            stores a Feat index (BYTE 0–255) referencing feats.2da. The game uses these to grant
            abilities such as Weapon Proficiency, Power Attack, or class-specific feats. Modders:
            add/remove feats to customize NPC capabilities. The creature must meet prereqs in
            feats.2da or the feat may have no effect. Duplicate feat IDs are allowed in the GFF but
            typically unnecessary. Use the Add/Remove buttons to manage entries.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_14">
          <property name="title">
           <string>Feat Summary</string>
          </property>
          <layout class="QGridLayout" name="gridLayout_4">
           <item row="0" column="0">
            <widget class="QPlainTextEdit" name="featSummaryEdit">
             <property name="toolTip">
              <string>Read-only summary of the creature's feats (GFF: FeatList). Lists feat names
               from feats.2da for each Feat index in the list. Add or remove feats using the Feat
               list above; this panel updates automatically. The game grants these feats when the
               creature loads.</string>
             </property>
             <property name="readOnly">
              <bool>true</bool>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="powersTab">
       <attribute name="title">
        <string>Powers</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_17" stretch="2,1">
        <item>
         <widget class="QListWidget" name="powerList">
          <property name="toolTip">
           <string>Force Power List (GFF: ClassList → KnownList0/1/2). Lists Force powers and spells
            known by this creature. Powers are stored per class in ClassList: each class has
            KnownList0 (level 1), KnownList1 (level 2), KnownList2 (level 3) containing Spell IDs
            (WORD 0–65535) that reference spells.2da. The game uses these for Jedi/Sith Force
            abilities and special attacks. Modders: add powers to grant Force Push, Heal, etc.;
            remove to restrict NPCs. Powers must match the creature's classes (e.g. Jedi Guardian
            powers for Guardian class). Invalid spell IDs are ignored at runtime.</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_29">
          <property name="title">
           <string>Force Power Summary</string>
          </property>
          <layout class="QGridLayout" name="gridLayout_8">
           <item row="0" column="0">
            <widget class="QPlainTextEdit" name="powerSummaryEdit">
             <property name="toolTip">
              <string>Read-only summary of the creature's Force powers and spells (GFF: ClassList →
               KnownList0/1/2). Lists power names from spells.2da. Add or remove powers using the
               Powers list above; this panel updates automatically. The game grants these abilities
               when the creature loads.</string>
             </property>
             <property name="readOnly">
              <bool>true</bool>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
      </widget>
