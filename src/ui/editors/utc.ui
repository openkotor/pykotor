               <property name="maximum">
                <number>127</number>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="toolTip">
                <string>Fortitude save bonus (GFF: fortbonus). Stored as SHORT; engine uses signed
                 byte range -128–127. Flat bonus added to Fortitude saving throws (Con-based).
                 In-game: added to base save + Con modifier. Modders: 0 = no bonus; negative values
                 weaken saves. Typical 0–10.</string>
               </property>
              </widget>
