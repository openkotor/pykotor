      <widget class="QWidget" name="tab">
       <attribute name="title">
        <string>Basic</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout" stretch="1,0,0,0">
        <item>
         <widget class="QGroupBox" name="groupBox">
          <property name="title">
           <string>Profile</string>
          </property>
          <layout class="QGridLayout" name="gridLayout_2">
           <item row="1" column="0">
            <layout class="QFormLayout" name="formLayout">
             <item row="0" column="0">
              <widget class="QLabel" name="label">
               <property name="text">
                <string>First Name:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout" stretch="0,0">
               <item>
                <widget class="LocalizedStringLineEdit" name="firstnameEdit" native="true">
                 <property name="toolTip">
                  <string>First Name (GFF: FirstName). CExoLocString stored in creature stats;
                   loaded and saved with the creature. The engine uses it wherever the creature's
                   display name is shown (dialogue, character sheet, targeting HUD). Resolved by
                   game language. Empty is valid. Modders: set the displayed name; use ? to
                   randomize from name tables. Scripts find creatures by Tag, not by this name.</string>
                 </property>
                 <property name="minimumSize">
                  <size>
                   <width>0</width>
                   <height>23</height>
                  </size>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="firstnameRandomButton">
                 <property name="toolTip">
                  <string>&lt;p&gt;&lt;b&gt;Randomize first name.&lt;/b&gt; Fills the First Name
                   field with a random entry from the name table (names.2da or game-specific
                   tables).&lt;/p&gt;&lt;p&gt;&lt;i&gt;Modders:&lt;/i&gt; Useful for quickly
                   generating generic NPC names. The game uses First Name in dialogue and the
                   character sheet; this button only edits the stored value.&lt;/p&gt;</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                 <property name="maximumSize">
                  <size>
                   <width>26</width>
                   <height>16777215</height>
                  </size>
                 </property>
                 <property name="text">
                  <string>?</string>
                 </property>
                </widget>
               </item>
              </layout>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_2">
               <property name="text">
                <string>Last Name:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_2" stretch="0,0">
               <item>
                <widget class="LocalizedStringLineEdit" name="lastnameEdit" native="true">
                 <property name="toolTip">
                  <string>Last Name (GFF: LastName). CExoLocString in creature stats; loaded and
                   saved with the creature. Displayed with first name in dialogue and UI. Empty is
                   valid. Modders: use ? to randomize. Scripts use Tag for lookups, not this field.</string>
                 </property>
                 <property name="minimumSize">
                  <size>
                   <width>0</width>
                   <height>23</height>
                  </size>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="lastnameRandomButton">
                 <property name="toolTip">
                  <string>Randomize last name. Fills the Last Name field with a random entry from
                   the name table. The game uses Last Name for dialogue and character display. This
                   button only edits the stored GFF value; it does not affect loading.</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                 <property name="maximumSize">
                  <size>
                   <width>26</width>
                   <height>16777215</height>
                  </size>
                 </property>
                 <property name="text">
                  <string>?</string>
                 </property>
                </widget>
               </item>
              </layout>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="label_3">
               <property name="text">
                <string>Tag:</string>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_3">
               <item>
                <widget class="QLineEdit" name="tagEdit">
                 <property name="toolTip">
                  <string>Tag (GFF: Tag). Loaded into creature stats and saved with the creature.
                   The script command GetObjectByTag(sTag, nNth) looks up objects by this string
                   (case-insensitive); the engine uses it for story logic and companion checks. If
                   multiple creatures share a tag, nNth selects which instance. Must be unique per
                   module for scripts that expect a single match. Empty is valid but scripts cannot
                   find this creature by tag. Modders: set a unique tag that matches any
                   GetObjectByTag calls in scripts/dialogue; changing a tag breaks existing
                   references.</string>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="tagGenerateButton">
                 <property name="toolTip">
                  <string>Generate tag from ResRef. Copies the Template ResRef (ResRef field) into
                   the Tag field, converting to a valid creature tag (lowercase, no extension).
                   Scripts and dialogues reference creatures by Tag; the tag must be unique per
                   area. Modders: use this to keep Tag and ResRef in sync when the ResRef is the
                   main identifier, or type a custom tag (e.g. for scripting).</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                 <property name="maximumSize">
                  <size>
                   <width>26</width>
                   <height>16777215</height>
                  </size>
                 </property>
                 <property name="text">
                  <string>-</string>
                 </property>
                </widget>
               </item>
               <item>
                <spacer name="horizontalSpacer">
                 <property name="orientation">
                  <enum>Qt::Horizontal</enum>
                 </property>
                 <property name="sizeType">
                  <enum>QSizePolicy::Fixed</enum>
                 </property>
                 <property name="sizeHint" stdset="0">
                  <size>
                   <width>32</width>
                   <height>0</height>
                  </size>
                 </property>
                </spacer>
               </item>
              </layout>
             </item>
             <item row="3" column="0">
              <widget class="QLabel" name="label_7">
               <property name="text">
                <string>ResRef:</string>
               </property>
              </widget>
             </item>
             <item row="3" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_8" stretch="0,0">
               <item>
                <widget class="QLineEdit" name="resrefEdit">
                 <property name="toolTip">
                  <string>Template ResRef (GFF: TemplateResRef). ResRef (max 16 characters)
                   identifying this creature template. The engine stores ResRefs in a 16-byte
                   structure; longer strings are truncated. When the game loads a creature from a
                   GIT file it can use this field to know which UTC template the instance uses; when
                   loading a UTC file directly the resource filename is the template resref.
                   In-game: used to load the correct UTC data for the creature. Modders: set this to
                   match the UTC filename (without .utc); keep under 16 characters. If you rename
                   the UTC file outside the toolset, update this field to match or references may
                   break. Empty is valid but unusual.</string>
                 </property>
                 <property name="maxLength">
                  <number>16</number>
                 </property>
                </widget>
               </item>
               <item>
                <spacer name="horizontalSpacer_2">
                 <property name="orientation">
                  <enum>Qt::Horizontal</enum>
                 </property>
                 <property name="sizeType">
                  <enum>QSizePolicy::Fixed</enum>
                 </property>
                 <property name="sizeHint" stdset="0">
                  <size>
                   <width>32</width>
                   <height>0</height>
                  </size>
                 </property>
                </spacer>
               </item>
              </layout>
             </item>
             <item row="4" column="0">
              <widget class="QLabel" name="label_4">
               <property name="text">
                <string>Appearance:</string>
               </property>
              </widget>
             </item>
             <item row="4" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_4">
               <item>
                <widget class="ComboBox2DA" name="appearanceSelect">
                 <property name="toolTip">
                  <string>Appearance (GFF: Appearance_Type). WORD index into appearance.2da. Picks
                   the 3D model and skin. Valid range 0 to 65535; use a row that exists in
                   appearance.2da or the model may not show. Modders: change to swap the creature's
                   look; the preview updates when you change this.</string>
                 </property>
                </widget>
               </item>
               <item>
                <spacer name="horizontalSpacer_5">
                 <property name="orientation">
                  <enum>Qt::Horizontal</enum>
                 </property>
                 <property name="sizeType">
                  <enum>QSizePolicy::Fixed</enum>
                 </property>
                 <property name="sizeHint" stdset="0">
                  <size>
                   <width>32</width>
                   <height>0</height>
                  </size>
                 </property>
                </spacer>
               </item>
              </layout>
             </item>
             <item row="5" column="0">
              <widget class="QLabel" name="label_10">
               <property name="text">
                <string>Soundset:</string>
               </property>
              </widget>
             </item>
             <item row="5" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_10">
               <item>
                <widget class="ComboBox2DA" name="soundsetSelect">
                 <property name="toolTip">
                  <string>Soundset (GFF: SoundSetFile). WORD index into soundset.2da. Chooses voice
                   and combat barks. Valid range 0 to 65535; use a valid row or sounds may be wrong.
                   Modders: pick a row from soundset.2da to change dialogue and battle sounds.</string>
                 </property>
                </widget>
               </item>
               <item>
                <spacer name="horizontalSpacer_6">
                 <property name="orientation">
                  <enum>Qt::Horizontal</enum>
                 </property>
                 <property name="sizeType">
                  <enum>QSizePolicy::Fixed</enum>
                 </property>
                 <property name="sizeHint" stdset="0">
                  <size>
                   <width>32</width>
                   <height>0</height>
                  </size>
                 </property>
                </spacer>
               </item>
              </layout>
             </item>
             <item row="6" column="0">
              <widget class="QLabel" name="label_5">
               <property name="text">
                <string>Conversation:</string>
               </property>
              </widget>
             </item>
             <item row="6" column="1">
              <layout class="QHBoxLayout" name="horizontalLayout_5">
               <item>
                <widget class="FilterComboBox" name="conversationEdit">
                 <property name="toolTip">
                  <string>Conversation (GFF: Conversation). ResRef of the dialogue (DLG) file; max
                   16 characters. When the player talks to this creature, the game runs this
                   dialogue. Blank means no dialogue. Modders: set to a DLG resref and use Edit to
                   open the dialogue editor.</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                   <horstretch>1</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QPushButton" name="conversationModifyButton">
                 <property name="toolTip">
                  <string>Open the dialogue editor for the Conversation (DLG) assigned to this
                   creature. The game runs this dialogue when the player talks to the creature. If
                   no conversation is set, this button may open a new or default dialogue. Modders:
                   use this to edit the creature's dialogue without leaving the UTC editor.</string>
                 </property>
                 <property name="sizePolicy">
                  <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                   <horstretch>0</horstretch>
                   <verstretch>0</verstretch>
                  </sizepolicy>
                 </property>
                 <property name="font">
                  <font>
                   <stylestrategy>PreferAntialias</stylestrategy>
                  </font>
                 </property>
                 <property name="text">
                  <string>Edit</string>
                 </property>
                </widget>
               </item>
               <item>
                <spacer name="horizontalSpacer_10">
                 <property name="orientation">
                  <enum>Qt::Horizontal</enum>
                 </property>
                 <property name="sizeType">
                  <enum>QSizePolicy::Fixed</enum>
                 </property>
                 <property name="sizeHint" stdset="0">
                  <size>
                   <width>32</width>
                   <height>0</height>
                  </size>
                 </property>
                </spacer>
               </item>
              </layout>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_15">
          <property name="title">
           <string>Inventory</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_10">
           <item>
            <widget class="QLabel" name="inventoryCountLabel">
             <property name="toolTip">
              <string>Shows how many items are in this creature's inventory (ItemList) plus equipped
               gear (Equip_ItemList). The game loads these when the creature spawns.</string>
             </property>
             <property name="text">
              <string>Total Items:</string>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="inventoryButton">
             <property name="toolTip">
              <string>Edit creature inventory (GFF: ItemList). Opens an editor where you can add,
               remove, or reorder items (UTI ResRefs) and equip them to slots. The game loads this
               list when the creature spawns; items appear in the creature's inventory and equipped
               slots in-game. Modders: add weapons, armor, and loot here; use Equipped slots to set
               what the creature has on (e.g. right hand, armor). Empty list is valid—creature
               starts with no items.</string>
             </property>
             <property name="text">
              <string>Edit Inventory</string>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_2">
          <property name="title">
           <string>Portrait</string>
          </property>
          <layout class="QHBoxLayout" name="horizontalLayout_7">
           <item>
            <widget class="QLabel" name="portraitPicture">
             <property name="toolTip">
              <string>Preview of the portrait image. Shows the portrait that will appear in dialogue
               and the party panel based on the Portrait (PortraitId) and optional Portrait ResRef
               settings above. This is display-only; change the Portrait dropdown or Portrait ResRef
               to change the image. If the selected row or resref is invalid, the preview may be
               blank or show a fallback.</string>
             </property>
             <property name="minimumSize">
              <size>
               <width>64</width>
               <height>64</height>
              </size>
             </property>
             <property name="maximumSize">
              <size>
               <width>64</width>
               <height>64</height>
              </size>
             </property>
             <property name="styleSheet">
              <string notr="true">background-color: black;</string>
             </property>
             <property name="frameShape">
              <enum>QFrame::Box</enum>
             </property>
             <property name="text">
              <string />
             </property>
             <property name="scaledContents">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item>
            <layout class="QHBoxLayout" name="horizontalLayout_6">
             <item>
              <widget class="ComboBox2DA" name="portraitSelect">
               <property name="toolTip">
                <string>Portrait (GFF: PortraitId). WORD. Image shown in dialogue and party panel.
                 Engine: if value &lt; 65534, use as portrait.2da row (0–65533); if 65534 or 65535,
                 use the Portrait ResRef field instead. The portrait can change with alignment
                 (light/dark) in-game. Modders: pick a row from portrait.2da (valid row 0–65533) or
                 use 65535 to use a custom Portrait ResRef; invalid rows may show a wrong or blank
                 portrait.</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <spacer name="verticalSpacer_5">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>40</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="advancedTab">
       <attribute name="title">
        <string>Advanced</string>
       </attribute>
       <layout class="QVBoxLayout" name="verticalLayout_4" stretch="1,1,0,0">
        <item>
         <widget class="QGroupBox" name="groupBox_3">
          <property name="title">
           <string>Flags</string>
          </property>
          <layout class="QHBoxLayout" name="horizontalLayout_9">
           <item>
            <layout class="QVBoxLayout" name="verticalLayout_2">
             <item>
              <widget class="QCheckBox" name="disarmableCheckbox">
               <property name="toolTip">
                <string>Disarmable (GFF: Disarmable). BYTE 0/1. If set, the creature can be disarmed
                 in combat (loses weapon). Modders: enable for NPCs that should be disarmable.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Minimum" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Disarmable</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="noPermDeathCheckbox">
               <property name="toolTip">
                <string>No Perm Death (GFF: NoPermDeath). BYTE 0 or 1. When checked (1), the
                 creature cannot be permanently killed and can be raised from death (e.g. by spells
                 or scripts). The game uses this for important NPCs that must stay revivable.
                 Unchecked (0) = normal death behavior. Does not stop the corpse from fading or
                 prevent scripts from destroying the object; use Plot or Min 1 HP for extra
                 protection. Modders: enable for NPCs that must reappear or be raiseable; leave off
                 for normal enemies. Note: KotOR 1 also reads the IsRaiseable field when loading
                 creatures; both affect whether the creature can be raised.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Minimum" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>No Perm Death</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="min1HpCheckbox">
               <property name="toolTip">
                <string>Min 1 HP (GFF: Min1HP). BYTE 0/1. If set, the creature's HP cannot go below
                 1 from damage. Modders: use for plot NPCs that must not die from damage (scripts
                 can still kill).</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Minimum" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Min 1 HP</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="plotCheckbox">
               <property name="toolTip">
                <string>Plot (GFF: Plot). BYTE 0/1. When set, the creature is plot-critical: the
                 game will not allow it to die permanently (e.g. companion NPCs). Does not prevent
                 knockdown or temporary death; scripts can still destroy the object. Modders: enable
                 for story-essential NPCs; leave off for normal enemies.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Minimum" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Plot</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="isPcCheckbox">
               <property name="toolTip">
                <string>Is PC (GFF: IsPC). BYTE 0/1. When set, the engine treats this creature as a
                 player character (e.g. for controls, camera, or UI). Rarely used on NPCs; mainly
                 for the player's creature in save games. Modders: leave unchecked for normal NPCs;
                 enabling can cause odd behavior.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Minimum" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Is PC</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <layout class="QVBoxLayout" name="verticalLayout_3">
             <item>
              <widget class="QCheckBox" name="noReorientateCheckbox">
               <property name="toolTip">
                <string>Doesn't Reorient on PC (GFF: NotReorienting). BYTE 0/1. When set, the
                 creature does not turn to face the player when the player approaches. Useful for
                 NPCs that should keep a fixed orientation (e.g. sitting, working). Modders: enable
                 for static or scripted facing.</string>
               </property>
               <property name="text">
                <string>Doesn't Reorientate on PC</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="noBlockCheckbox">
               <property name="toolTip">
                <string>Doesn't Block PC (GFF: IgnoreCrePath). BYTE 0/1. When set, the creature is
                 ignored by pathfinding: the player and party can walk through it. Useful for
                 non-solid NPCs or holograms. Modders: enable for ghosts, holograms, or decorative
                 creatures that should not block movement.</string>
               </property>
               <property name="text">
                <string>Doesn't Block PC</string>
               </property>
              </widget>
             </item>
             <item>
              <widget class="QCheckBox" name="hologramCheckbox">
               <property name="toolTip">
                <string>Hologram (GFF: Hologram). BYTE 0/1. When set, the creature is rendered as a
                 hologram (shader effect). Used for holographic NPCs in KotOR. Modders: enable for
                 holocomm or hologram encounters; has no effect on dialogue or scripts.</string>
               </property>
               <property name="text">
                <string>Hologram</string>
               </property>
              </widget>
             </item>
             <item>
              <spacer name="verticalSpacer">
               <property name="orientation">
                <enum>Qt::Vertical</enum>
               </property>
               <property name="sizeHint" stdset="0">
                <size>
                 <width>20</width>
                 <height>40</height>
                </size>
               </property>
              </spacer>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_4">
          <property name="title">
           <string>Race</string>
          </property>
          <layout class="QFormLayout" name="formLayout_2">
           <item row="0" column="0">
            <widget class="QLabel" name="label_8">
             <property name="text">
              <string>Race:</string>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="ComboBox2DA" name="raceSelect">
             <property name="toolTip">
              <string>Race (GFF: Race). Index into racialtypes.2da (row 0, 1, 2, …). The game uses
               this for hit dice, skill points, available classes, model options, and race-specific
               checks. Modders: choose a row that exists in racialtypes.2da (e.g. Human, Droid).
               Important: if the value is greater than or equal to the number of rows in race.2da,
               the creature will fail to load in-game. Keep the index within the valid range for
               your game/mod.</string>
             </property>
             <property name="sizePolicy">
              <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
               <horstretch>0</horstretch>
               <verstretch>0</verstretch>
              </sizepolicy>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="label_9">
             <property name="text">
              <string>Subrace:</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1">
            <widget class="ComboBox2DA" name="subraceSelect">
             <property name="toolTip">
              <string>Subrace (GFF: SubraceIndex). Index into subrace.2da; refines the selected race
               (e.g. subspecies). The game uses this for appearance and sometimes stat tweaks.
               Modders: use a row that exists in subrace.2da and matches the race; 0 is often valid.
               Invalid indices are not rejected by the engine but can cause odd appearance or
               behavior.</string>
             </property>
             <property name="sizePolicy">
              <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
               <horstretch>0</horstretch>
               <verstretch>0</verstretch>
              </sizepolicy>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="groupBox_5">
          <property name="title">
           <string>Other</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_18">
           <item>
            <layout class="QFormLayout" name="formLayout_3">
             <item row="0" column="0">
              <widget class="QLabel" name="label_16">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>1</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Speed:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="ComboBox2DA" name="speedSelect">
               <property name="toolTip">
                <string>Speed (GFF: WalkRate). Row index into creaturespeed.2da (WALKRATE column).
                 The game uses this value to set the creature's walk and run movement speed for
                 pathfinding and animation. Modders: choose a row that exists in creaturespeed.2da
                 (typically 0 to number of rows minus one). An invalid index may result in default
                 speed or broken movement in-game.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_11">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>1</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Faction:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="ComboBox2DA" name="factionSelect">
               <property name="toolTip">
                <string>Faction (GFF: FactionID). Index into repute.2da (or faction table).
                 Determines who the creature is hostile or friendly to. The game uses this for
                 combat targeting and dialogue reactions. Modders: set to match your module's
                 factions; wrong values can make NPCs attack the party or ignore enemies.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="genderAdvancedLabel">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>1</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Gender:</string>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="ComboBox2DA" name="genderSelect">
               <property name="toolTip">
                <string>Gender (GFF: Gender). BYTE index into gender.2da (0=Male, 1=Female, etc.).
                 The game clamps values over 4 to 4 when loading. Affects voice, name tables, and
                 appearance. Used for dialogue and LTR name generation. Modders: use 0–4; must match
                 a row in gender.2da or the engine clamps to 4. Edge case: values above 4 in the GFF
                 are clamped when loaded.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
              </widget>
             </item>
             <item row="3" column="0">
              <widget class="QLabel" name="label_12">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>1</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Perception:</string>
               </property>
              </widget>
             </item>
             <item row="3" column="1">
              <widget class="ComboBox2DA" name="perceptionSelect">
               <property name="toolTip">
                <string>Perception (GFF: PerceptionRange). Stored as BYTE (0–255). Row index into
                 ranges.2da that defines primary and secondary detection range (how far the creature
                 can see and hear). The game uses this for AI awareness, stealth detection, and
                 targeting. Default for NPCs is 11 when missing. Special: value 12 (0xC) uses the
                 appearance's PERCEPTIONDIST from appearance.2da instead of a ranges.2da row.
                 Invalid row indices can cause the creature to fail to load in-game (engine error).
                 Modders: pick a valid row from ranges.2da; higher row indices generally mean larger
                 perception range. Only used for non-player creatures; PCs use a fixed range.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
              </widget>
             </item>
             <item row="4" column="0">
              <widget class="QLabel" name="label_13">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>1</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Challenge Rating:</string>
               </property>
              </widget>
             </item>
             <item row="4" column="1">
              <widget class="QDoubleSpinBox" name="challengeRatingSpin">
               <property name="minimum">
                <double>0.000000000000000</double>
               </property>
               <property name="maximum">
                <double>100.000000000000000</double>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="toolTip">
                <string>Challenge Rating (GFF: ChallengeRating). FLOAT. Used by the game for
                 encounter difficulty and XP calculations. Modders: set 0–100; higher values make
                 the creature count as tougher for reward and scaling. Has no effect on actual
                 combat stats.</string>
               </property>
              </widget>
             </item>
            </layout>
           </item>
           <item>
            <widget class="QFrame" name="k2onlyBox">
             <property name="frameShape">
              <enum>QFrame::NoFrame</enum>
             </property>
             <property name="frameShadow">
              <enum>QFrame::Plain</enum>
             </property>
             <layout class="QFormLayout" name="formLayout_24">
              <property name="leftMargin">
               <number>0</number>
              </property>
              <property name="topMargin">
               <number>0</number>
              </property>
              <property name="rightMargin">
               <number>0</number>
              </property>
              <property name="bottomMargin">
               <number>0</number>
              </property>
              <item row="1" column="0">
               <widget class="QLabel" name="label_102">
                <property name="sizePolicy">
                 <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                  <horstretch>1</horstretch>
                  <verstretch>0</verstretch>
                 </sizepolicy>
                </property>
                <property name="text">
                 <string>Blindspot:</string>
                </property>
               </widget>
              </item>
              <item row="1" column="1">
               <widget class="QDoubleSpinBox" name="blindSpotSpin">
                <property name="minimum">
                 <double>0.000000000000000</double>
                </property>
                <property name="maximum">
                 <double>360.000000000000000</double>
                </property>
                <property name="toolTip">
                 <string>Blindspot (GFF: BlindSpot). KotOR 2 only. FLOAT. Angle in degrees behind
                  the creature that is not perceived. Modders: 0 = no blind spot; 360 = effectively
                  blind. Used by AI perception.</string>
                </property>
               </widget>
              </item>
              <item row="2" column="0">
               <widget class="QLabel" name="label_110">
                <property name="sizePolicy">
                 <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                  <horstretch>1</horstretch>
                  <verstretch>0</verstretch>
                 </sizepolicy>
                </property>
                <property name="text">
                 <string>Multiplier Set:</string>
                </property>
               </widget>
              </item>
              <item row="0" column="1">
               <widget class="Line" name="line">
                <property name="orientation">
                 <enum>Qt::Horizontal</enum>
                </property>
               </widget>
              </item>
              <item row="2" column="1">
               <widget class="QSpinBox" name="multiplierSetSpin">
                <property name="toolTip">
                 <string>Multiplier Set (GFF: MultiplierSet). KotOR 2 only. Stored as BYTE (0–255).
                  Used for encounter scaling (e.g. difficulty or reward multipliers). The game reads
                  and writes this when saving creature stats. Modders: use 0 for default behavior;
                  other values depend on game scripts and encounter tables. Invalid or out-of-range
                  values may have no effect or use default. Leave 0 if unsure.</string>
                </property>
                <property name="minimum">
                 <number>0</number>
                </property>
                <property name="maximum">
                 <number>255</number>
                </property>
               </widget>
              </item>
             </layout>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <spacer name="verticalSpacer_4">
          <property name="orientation">
           <enum>Qt::Vertical</enum>
          </property>
          <property name="sizeHint" stdset="0">
           <size>
            <width>20</width>
            <height>40</height>
           </size>
          </property>
         </spacer>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="statsTab">
       <attribute name="title">
        <string>Stats</string>
       </attribute>
       <layout class="QHBoxLayout" name="horizontalLayout_11">
        <item>
         <layout class="QVBoxLayout" name="verticalLayout_5">
          <item>
           <widget class="QGroupBox" name="groupBox_6">
            <property name="sizePolicy">
             <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
              <horstretch>0</horstretch>
              <verstretch>0</verstretch>
             </sizepolicy>
            </property>
            <property name="title">
             <string>Skills</string>
            </property>
            <layout class="QFormLayout" name="formLayout_4">
             <item row="0" column="0">
              <widget class="QLabel" name="label_17">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Computer Use:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QSpinBox" name="computerUseSpin">
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="toolTip">
                <string>Computer Use (GFF: SkillList Rank for this skill). BYTE 0–255. Base skill
                 rank before modifiers. In-game: used for computer spikes, hacking, droid repair.
                 Modders: typical ranks 0–30; 255 is max. Cross-class ranks may use negative values
                 internally; editor uses 0–255.</string>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_18">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Demolitions:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QSpinBox" name="demolitionsSpin">
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="toolTip">
                <string>Demolitions (GFF: SkillList Rank). BYTE 0–255. Base rank for placing and
                 disarming mines and explosives. In-game: affects trap DC and disarm checks.
                 Modders: 0–30 typical; 255 max.</string>
               </property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="label_19">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Stealth:</string>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="QSpinBox" name="stealthSpin">
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="toolTip">
                <string>Stealth (GFF: SkillList Rank). BYTE 0–255. Base rank for hiding and moving
                 silently. In-game: opposed by Awareness; affects detection range. Modders: 0–30
                 typical.</string>
               </property>
              </widget>
             </item>
             <item row="3" column="0">
              <widget class="QLabel" name="label_20">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Awareness:</string>
               </property>
              </widget>
             </item>
             <item row="3" column="1">
              <widget class="QSpinBox" name="awarenessSpin">
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="toolTip">
                <string>Awareness (GFF: SkillList Rank). BYTE 0–255. Base rank for spotting traps,
                 stealth, and hidden objects. In-game: opposed by Stealth; affects perception.
                 Modders: 0–30 typical.</string>
               </property>
              </widget>
             </item>
             <item row="4" column="0">
              <widget class="QLabel" name="label_21">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Persuade:</string>
               </property>
              </widget>
             </item>
             <item row="4" column="1">
              <widget class="QSpinBox" name="persuadeSpin">
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="toolTip">
                <string>Persuade (GFF: SkillList Rank). BYTE 0–255. Base rank for dialogue
                 persuasion and intimidation. In-game: affects [Persuade] options and DCs. Modders:
                 0–30 typical; high values make dialogue checks easier.</string>
               </property>
              </widget>
             </item>
             <item row="5" column="0">
              <widget class="QLabel" name="label_22">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Repair:</string>
               </property>
              </widget>
             </item>
             <item row="5" column="1">
              <widget class="QSpinBox" name="repairSpin">
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>255</number>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="toolTip">
                <string>Repair (GFF: SkillList Rank). BYTE 0–255. Base rank for repairing items and
                 droids. In-game: affects repair DCs and droid healing. Modders: 0–30 typical.</string>
               </property>
              </widget>
             </item>
             <item row="6" column="0">
              <widget class="QLabel" name="label_23">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Security:</string>
               </property>
              </widget>
             </item>
             <item row="6" column="1">
              <widget class="QSpinBox" name="securitySpin">
               <property name="minimum">
                <number>0</number>
