                <string>Base HP:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_36">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Current HP:</string>
               </property>
              </widget>
             </item>
             <item row="2" column="0">
              <widget class="QLabel" name="label_37">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Max HP:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QSpinBox" name="baseHpSpin">
               <property name="toolTip">
                <string>Base HP (GFF: HitPoints). SHORT. Read by the engine in ReadStatsFromGff;
                 stored as object.hit_points (max HP before modifiers). Default when missing: 0.
                 In-game: used as base for NPC max HP calculation (with Con modifier and level).
                 Modders: valid range 0–32767 (signed 16-bit); for blueprints often matches or is
                 less than Max HP. Negative values are not used by the game.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>32767</number>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QSpinBox" name="currentHpSpin">
               <property name="toolTip">
                <string>Current HP (GFF: CurrentHitPoints). SHORT. Creature's current hit points
                 when the template is loaded; can exceed Max HP from temporary buffs. Default when
                 missing: 0. In-game: the engine reads this then for NPCs may recompute current HP
                 via SetCurrentHitPoints (level + Con modifier); combat and healing update this at
                 runtime. Modders: valid range 0–32767; for blueprints set equal to Max HP for a
                 full-health start. The game does not use negative HP.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>32767</number>
               </property>
              </widget>
             </item>
             <item row="2" column="1">
              <widget class="QSpinBox" name="maxHpSpin">
               <property name="toolTip">
                <string>Max HP (GFF: MaxHitPoints). SHORT. Maximum hit points after level and Con;
                 the creature cannot exceed this from healing. Default when missing: 0. In-game:
                 ceiling for healing and display. Modders: valid range 0–32767; usually ≥ Current
                 HP; often derived from Base HP + Con. Edge case: if Current HP &gt; Max HP (e.g.
                 buffs), the engine may still use the stored value until next update.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>32767</number>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <widget class="QGroupBox" name="groupBox_11">
            <property name="title">
             <string>Force Points</string>
            </property>
            <layout class="QFormLayout" name="formLayout_9">
             <item row="0" column="0">
              <widget class="QLabel" name="label_39">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Current FP:</string>
               </property>
              </widget>
             </item>
             <item row="0" column="1">
              <widget class="QSpinBox" name="currentFpSpin">
               <property name="toolTip">
                <string>Current FP (GFF: CurrentForce). SHORT. Current Force points when the
                 template is loaded; used by Jedi/Sith for powers. Default when missing: 0. In-game:
                 engine reads this then for NPCs may set max FP from level and Wis/Cha modifiers.
                 Modders: valid range 0–32767; for NPCs often set equal to Max FP for full Force.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>32767</number>
               </property>
              </widget>
             </item>
             <item row="1" column="0">
              <widget class="QLabel" name="label_40">
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="text">
                <string>Max FP:</string>
               </property>
              </widget>
             </item>
             <item row="1" column="1">
              <widget class="QSpinBox" name="maxFpSpin">
               <property name="toolTip">
                <string>Max FP (GFF: ForcePoints). SHORT. Maximum Force points (from level and
                 Wis/Cha modifiers). Default when missing: 0. In-game: ceiling for Force recovery;
                 Jedi/Sith use this for power costs. Modders: valid range 0–32767; usually ≥ Current
                 FP.</string>
               </property>
               <property name="sizePolicy">
                <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                 <horstretch>0</horstretch>
                 <verstretch>0</verstretch>
                </sizepolicy>
               </property>
               <property name="minimum">
                <number>0</number>
               </property>
               <property name="maximum">
                <number>32767</number>
               </property>
              </widget>
             </item>
            </layout>
           </widget>
          </item>
          <item>
           <spacer name="verticalSpacer_2">
            <property name="orientation">
             <enum>Qt::Vertical</enum>
            </property>
            <property name="sizeHint" stdset="0">
             <size>
